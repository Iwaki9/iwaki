def run_autonomous_batch(*, mega_link: str, langs: str = 'en', upload: str = 'api', yt_max_height: int = 1080, **overrides):
    profile = {**DEFAULTS, **overrides}
    _ensure_dirs()
    
    sec = _secrets()
    sftp_pw = sec.get_secret('SFTP_PASS') if sec else None
    token = sec.get_secret('UPLOAD_API_TOKEN') if sec else None
    if not sftp_pw: raise RuntimeError("Секрет SFTP_PASS необходим!")
    
    print("Проверка подключения к SFTP...")
    _get_remote_states(profile, sftp_pw)
    print("✅ Успешная авторизация на SFTP.")

    from colab_pipeline import setup_pot_provider
    setup_pot_provider()
    
    shutil.rmtree(SRC_DIR, ignore_errors=True); SRC_DIR.mkdir(parents=True, exist_ok=True)
    print("📥 Шаг 1: Скачивание всей метаструктуры папки MEGA (только субтитры)...")
    subprocess.run(['mega-get', mega_link, str(SRC_DIR)], check=True)
    print("✅ Структура Меги успешно скопирована локально.")

    script = _ensure_script(profile['logo_dir'])
    yt_cookies = '/content/yt_cookies.txt' if Path('/content/yt_cookies.txt').exists() else None

    links_files = sorted(SRC_DIR.rglob('links.txt'))
    global_pool = []

    print("\n🔍 Шаг 2: Анализ подпапок Меги и развертывание плейлистов YouTube...")
    for links_txt in links_files:
        folder = links_txt.parent
        name_txt = folder / 'name.txt'
        series_name = name_txt.read_text(encoding='utf-8').strip().splitlines()[0] if name_txt.exists() else folder.name
        
        links = [line.strip() for line in links_txt.read_text(encoding='utf-8').splitlines() if line.strip() and not line.startswith('#')]
        if not links: continue

        sub_index = {}
        for srt in folder.glob('*.srt'):
            lang_code = parse_subtitle_lang(srt.name)
            if not lang_code or lang_code not in langs.split(','): continue
            clean_stem = re.sub(r'\.[a-zA-Zа-яА-Я]{2,12}$', '', srt.with_suffix('').name)
            for aliases in LANG_ALIASES.values():
                for a in aliases:
                    if clean_stem.lower().endswith(' ' + a): clean_stem = clean_stem[:-len(a)-1].rstrip(); break
            ep = parse_episode_number(clean_stem)
            if ep is not None: sub_index[(ep, lang_code)] = srt

        if not sub_index: continue

        for link in links:
            info = _ytdlp_extract_with_fallback(link, yt_cookies, flat=True)
            if not info: continue
            
            entries = info.get('entries', [info]) if 'entries' in info or info.get('_type') == 'playlist' else [info]
            for entry in entries:
                if not entry: continue
                title = entry.get('title', '')
                v_url = entry.get('url') or f"https://www.youtube.com/watch?v={entry.get('id')}"
                ep = parse_episode_number(title)
                
                if ep is not None:
                    matched_srts = {l: sub_index[(ep, l)] for l in langs.split(',') if (ep, l) in sub_index}
                    if matched_srts:
                        global_pool.append({
                            'folder_name': folder.name, 'series_name': series_name,
                            'url': v_url, 'ep': ep, 'srts': matched_srts
                        })

    print(f"\n🎯 Анализ завершен. Всего в глобальной очереди YouTube обнаружено: {len(global_pool)} серий.")
    tg_send(f'🚀 Сервер Colab подключился к распределенной очереди.\nВсего в пуле: <b>{len(global_pool)} серий</b>')

    processed_count = 0
    for task in global_pool:
        safe_series = re.sub(r'[<>:"/\\|?*]', '_', task['series_name']).strip()
        marker_base_name = f"{safe_series} {task['ep']}. Bölüm"

        states = _get_remote_states(profile, sftp_pw)
        target_langs_to_render = []
        is_locked_by_neighbor = False

        for lang in langs.split(','):
            l_code = lang.strip()
            full_filename = f"{marker_base_name}.{l_code}.mp4"
            
            if f"{full_filename}.done" in states: continue 
            if f"{full_filename}.lock" in states:
                is_locked_by_neighbor = True; break 
                
            target_langs_to_render.append(l_code)

        if is_locked_by_neighbor or not target_langs_to_render:
            continue 

        print(f"\n🔒 Бронирую серию {task['ep']} сериала '{task['series_name']}'...")
        for l_code in target_langs_to_render:
            _add_lock_marker(profile, sftp_pw, f"{marker_base_name}.{l_code}.mp4")

        for p in (VIDEO_DIR, SUBS_DIR, OUT_DIR):
            shutil.rmtree(p, ignore_errors=True); p.mkdir(parents=True, exist_ok=True)

        for l_code in target_langs_to_render:
            if l_code in task['srts']:
                shutil.copy2(task['srts'][l_code], SUBS_DIR / f"{marker_base_name}.{l_code}.srt")

        print(f"📥 Конвейер: Скачивание video-потока с YouTube...")
        v_file = download_youtube_video(task['url'], VIDEO_DIR, cookies=yt_cookies, max_height=yt_max_height)
        
        if not v_file or not v_file.exists():
            print("❌ Сбой скачивания с YouTube. Снимаю бронь ноды.")
            for l_code in target_langs_to_render: _remove_lock_marker(profile, sftp_pw, f"{marker_base_name}.{l_code}.mp4")
            continue

        target_video_path = VIDEO_DIR / f"{marker_base_name}.mp4"
        v_file.rename(target_video_path)

        print("⚙️ Конвейер: Старт рендеринга хардсаба...")
        print("="*70)
        cmd = ['python', '-u', str(script), '--once', '--video-dir', str(VIDEO_DIR), '--subtitle-dir', str(SUBS_DIR), '--logo-dir', profile['logo_dir'], '--output-dir', str(OUT_DIR), '--log-dir', str(LOG_DIR), '--dest-langs', ','.join(target_langs_to_render), '--encoder', profile['encoder'], '--naming', 'stem', '--skip-translation']
        
        proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)
        while True:
            line = proc.stdout.readline()
            if not line: break
            print(line, end='', flush=True)
        proc.wait()

        if proc.returncode != 0:
            print("❌ Ошибка сборки. Снимаю лок-маркеры.")
            for l_code in target_langs_to_render: _remove_lock_marker(profile, sftp_pw, f"{marker_base_name}.{l_code}.mp4")
            continue

        outputs = sorted(p for p in OUT_DIR.glob('*.mp4') if p.is_file())
        if outputs:
            print(f"📤 Конвейер: Заливка на API-сервер...")
            for out_f in outputs:
                ok = _api_upload(out_f, profile['api_server'], profile['api_hostings'], token, profile['api_speed_limit_mbps'], profile['api_speed_time_sec'], profile['api_max_retries'])
                if ok:
                    print(f"   ✅ Залит на хостинги: {out_f.name}")
                    _convert_lock_to_done(profile, sftp_pw, out_f.name)
                else:
                    print(f"   ❌ Сбой заливки API: {out_f.name}. Возврат очереди.")
                    _remove_lock_marker(profile, sftp_pw, out_f.name)

        processed_count += 1
        shutil.rmtree(VIDEO_DIR, ignore_errors=True)
        shutil.rmtree(OUT_DIR, ignore_errors=True)

    print(f"\n🏁 Очередь пуста. Нода завершила работу. Сделано: {processed_count} серий.")
    tg_send(f'🏁 Нода кластера выполнила задачи очереди.')

