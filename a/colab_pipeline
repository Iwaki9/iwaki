def _get_remote_states(p: dict, password: str) -> set[str]:
    env = os.environ.copy()
    env.update(SFTP_PASS=password)
    bdir = f"{p['sftp_path']}/.blacklist"
    cmd = f'lftp -u "{p["sftp_user"]},$SFTP_PASS" -p "{p["sftp_port"]}" "sftp://{p["sftp_host"]}" -e "set cmd:fail-exit yes; mkdir -p \\"{bdir}\\"; cls -1 \\"{bdir}\\"; quit"'
    r = subprocess.run(['bash', '-c', cmd], capture_output=True, text=True, env=env)
    if r.returncode != 0:
        raise RuntimeError(f"❌ Ошибка подключения к SFTP! Проверь пароль.\nЛог:\n{r.stderr}")
    return {line.strip() for line in r.stdout.splitlines() if line.strip()}

def _add_lock_marker(p: dict, password: str, marker_name: str):
    env = os.environ.copy()
    env.update(SFTP_PASS=password)
    bdir = f"{p['sftp_path']}/.blacklist"
    tmp_f = Path(f"/tmp/lock_node.tmp")
    tmp_f.touch()
    cmd = f'lftp -u "{p["sftp_user"]},$SFTP_PASS" -p "{p["sftp_port"]}" "sftp://{p["sftp_host"]}" -e "set cmd:fail-exit yes; mkdir -p \\"{bdir}\\"; put \\"{tmp_f}\\" -o \\"{bdir}/{marker_name}.lock\\"; quit"'
    r = subprocess.run(['bash', '-c', cmd], capture_output=True, text=True, env=env)
    tmp_f.unlink(missing_ok=True)
    if r.returncode != 0:
        raise RuntimeError(f"❌ Не удалось создать .lock файл на SFTP:\n{r.stderr}")

def _convert_lock_to_done(p: dict, password: str, marker_name: str):
    env = os.environ.copy()
    env.update(SFTP_PASS=password)
    bdir = f"{p['sftp_path']}/.blacklist"
    tmp_done = Path(f"/tmp/done_node.tmp")
    tmp_done.touch()
    cmd = f'lftp -u "{p["sftp_user"]},$SFTP_PASS" -p "{p["sftp_port"]}" "sftp://{p["sftp_host"]}" -e "set cmd:fail-exit yes; mkdir -p \\"{bdir}\\"; rm -f \\"{bdir}/{marker_name}.lock\\"; put \\"{tmp_done}\\" -o \\"{bdir}/{marker_name}.done\\"; quit"'
    r = subprocess.run(['bash', '-c', cmd], capture_output=True, text=True, env=env)
    tmp_done.unlink(missing_ok=True)
    if r.returncode != 0:
        print(f"⚠️ Ошибка обновления статуса .lock -> .done на SFTP:\n{r.stderr}")

def _remove_lock_marker(p: dict, password: str, marker_name: str):
    env = os.environ.copy()
    env.update(SFTP_PASS=password)
    bdir = f"{p['sftp_path']}/.blacklist"
    cmd = f'lftp -u "{p["sftp_user"]},$SFTP_PASS" -p "{p["sftp_port"]}" "sftp://{p["sftp_host"]}" -e "set cmd:fail-exit yes; rm -f \\"{bdir}/{marker_name}.lock\\"; quit"'
    subprocess.run(['bash', '-c', cmd], env=env, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

