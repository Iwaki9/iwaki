# YT-DLP ДВИЖОК СКАЧИВАНИЯ (H.264 HD 1080p/720p)
# =========================================================
def _ytdlp_extract_with_fallback(url: str, cookies: Optional[str], flat: bool) -> Optional[dict]:
    from yt_dlp import YoutubeDL
    for clients in YTDLP_CLIENT_VARIANTS:
        opts = {'quiet': True, 'no_warnings': True, 'skip_download': True, 'extract_flat': 'in_playlist' if flat else False}
        if clients: opts['extractor_args'] = {'youtube': {'player_client': clients}}
        if cookies and Path(cookies).exists(): opts['cookiefile'] = cookies
        try:
            with YoutubeDL(opts) as ydl:
                info = ydl.extract_info(url, download=False)
                if info: return info
            if _POT_PROVIDER_AVAILABLE:
                opts['extractor_args'] = {'youtube': {'player_client': ['default', 'mweb']}}
                with YoutubeDL(opts) as ydl:
                    info = ydl.extract_info(url, download=False)
                    if info: return info
        except Exception: continue
    return None

def download_youtube_video(url: str, output_dir: Path, cookies: Optional[str] = None, max_height: int = 1080) -> Optional[Path]:
    from yt_dlp import YoutubeDL
    info = _ytdlp_extract_with_fallback(url, cookies, flat=False)
    if not info: return None
    output_dir.mkdir(parents=True, exist_ok=True)
    out_tmpl = str(output_dir / '%(id)s.%(ext)s')
    fmt = f'bestvideo[ext=mp4][vcodec^=avc1][height<={max_height}]+bestaudio[ext=m4a]/bestvideo[vcodec^=avc1][height<={max_height}]+bestaudio[ext=m4a]/best[ext=mp4]/best'
    
    opts = {
        'format': fmt, 
        'outtmpl': out_tmpl, 
        'quiet': True, 
        'no_warnings': True, 
        'merge_output_format': 'mp4',
        'rm_cached_dir': True
    }
    try:
        with YoutubeDL(opts) as ydl:
            info_download = ydl.extract_info(url, download=True)
            for f in output_dir.iterdir():
                if f.stem == info_download['id']: return f
    except Exception: pass
    return None

def _api_upload(fpath: Path, server, hostings, token, speed_limit_mbps=2, speed_time_sec=120, max_retries=3):
    for attempt in range(1, max_retries + 1):
        args = ['curl', '-sS', '--fail-with-body', '-X', 'POST', '--connect-timeout', '30', '-H', f'X-API-Key: {token}', '-F', f'files=@{fpath}']
        for h in hostings: args += ['-F', f'hostings={h}']
        args += [f'{server}/api/upload']
        r = subprocess.run(args, capture_output=True, text=True, timeout=7200)
        if r.returncode == 0: return True
        time.sleep(5)
    return False

