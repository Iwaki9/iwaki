def parse_episode_number(text: str) -> Optional[int]:
    if not text: return None
    s = re.sub(r'\.(srt|mp4|mkv|avi|mov|json|txt)$', '', text, flags=re.IGNORECASE)
    patterns = [
        r'(\d+)\.\s*Bölüm', r'Bölüm\s*(\d+)',
        r'(\d+)\s*серия', r'серия\s*(\d+)',
        r'(?:Episode|Ep\.?)\s*(\d+)', r'S\d+E(\d+)',
    ]
    for pat in patterns:
        m = re.search(pat, s, re.IGNORECASE)
        if m: return int(m.group(1))
    nums = re.findall(r'\d+', s)
    if nums:
        candidates = [int(n) for n in nums if int(n) < 1000]
        if candidates: return candidates[-1]
    return None

def parse_subtitle_lang(filename: str) -> Optional[str]:
    stem = re.sub(r'\.srt$', '', filename, flags=re.IGNORECASE)
    m = re.match(r'^.+\.([a-zA-Zа-яА-Я]{2,12})$', stem)
    if m and m.group(1).lower() in _ALIAS_TO_CODE:
        return _ALIAS_TO_CODE[m.group(1).lower()]
    parts = stem.split()
    if parts and parts[-1].lower() in _ALIAS_TO_CODE:
        return _ALIAS_TO_CODE[parts[-1].lower()]
    return None

