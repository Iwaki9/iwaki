def _resolve_drive_folder(folder: str, parent_id: Optional[str]) -> str:
    """
    Возвращает URL или ID Drive-папки для gdown.download_folder.

    Логика:
      • Если folder выглядит как полный URL drive.google.com — возвращаем как есть.
      • Если folder выглядит как длинный ID (>= 20 символов) — это полноценный ID.
      • Иначе считаем что это имя подпапки внутри parent_id. Тогда строим
        URL вида https://drive.google.com/drive/folders/<parent_id> а gdown
        сам скачает всю иерархию, и мы потом возьмём только нужную подпапку.
        Но это медленно если в parent_id много подпапок.
        Поэтому пробуем найти конкретный ID подпапки через Drive API
        (публичный, без auth — работает только для shared папок).
    """
    if folder.startswith('http'):
        return folder
    if len(folder) >= 20 and '/' not in folder:
        # Похоже на полноценный ID
        return folder

    # Иначе это имя подпапки внутри parent_id
    if not parent_id:
        raise RuntimeError(
            f'folder="{folder}" — это имя подпапки, но drive_parent_id не задан. '
            f'Добавь в kp.run(... drive_parent_id="ID_главной_папки") '
            f'или поправь DEFAULTS в kaggle_pipeline.py'
        )

    # Попробуем найти ID подпапки через scraping публичной HTML-страницы Drive.
    # Это работает для папок с "Anyone with the link".
    import re as _re
    import urllib.request as _ureq

    url = f'https://drive.google.com/drive/folders/{parent_id}'
    print(f'🔍 Ищу подпапку "{folder}" в {url} ...')
    try:
        req = _ureq.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with _ureq.urlopen(req, timeout=15) as r:
            html = r.read().decode('utf-8', errors='replace')
    except Exception as e:
        raise RuntimeError(
            f'Не могу загрузить страницу родительской папки: {e}\n'
            f'Убедись что drive_parent_id корректный и папка доступна по ссылке.'
        )

    # Google Drive рендерит каждую запись как:
    #   <tr data-selectable data-id="ID" ...>...имя где-то внутри...</tr>
    # Извлекаем все блоки <tr ... data-id="..."> ... </tr> и ищем имя внутри.
    items = {}  # name -> id

    def _clean_name(raw: str) -> str:
        """
        Drive отдаёт имя как 'Foo Shared folder' / 'Foo Folder' / 'Foo, Last modified ...'
        Чистим эти суффиксы.
        """
        n = raw.strip()
        # Запятая и всё после неё (часто 'aria-label="Имя, Last modified ..."')
        if ',' in n:
            n = n.split(',', 1)[0].strip()
        # Известные суффиксы Drive
        for suf in (' Shared folder', ' Shared Folder', ' Folder', ' folder'):
            if n.endswith(suf):
                n = n[: -len(suf)].rstrip()
                break
        return n

    # Сначала пробуем строгий формат с data-id
    for m in _re.finditer(
        r'<tr[^>]*\sdata-id="([0-9A-Za-z_-]{20,})"[^>]*>(.*?)</tr>',
        html, _re.DOTALL,
    ):
        item_id = m.group(1)
        block = m.group(2)
        name = None
        m2 = _re.search(r'data-tooltip="([^"]+)"', block)
        if m2:
            name = _clean_name(m2.group(1))
        if not name:
            m2 = _re.search(r'aria-label="([^"]+)"', block)
            if m2:
                name = _clean_name(m2.group(1))
        if not name:
            text = _re.sub(r'<[^>]+>', ' ', block)
            text = _re.sub(r'\s+', ' ', text).strip()
            if text:
                name = text.split(' ')[0]
        if name:
            items[name] = item_id

    # Если строгий формат ничего не дал — пробуем JSON-данные в скриптах
    if not items:
        for m in _re.finditer(
            r'"([0-9A-Za-z_-]{20,})"[^"]{0,200}?"([^"\\]+)"',
            html,
        ):
            candidate_id, candidate_name = m.group(1), _clean_name(m.group(2))
            if len(candidate_name) < 200 and '<' not in candidate_name and '\\' not in candidate_name:
                items.setdefault(candidate_name, candidate_id)

    if folder in items:
        sub_id = items[folder]
        print(f'✅ Подпапка "{folder}" найдена: {sub_id}')
        return sub_id

    # Не нашлось — диагностика
    all_names = sorted(items.keys())[:30]
    raise RuntimeError(
        f'В папке {parent_id} не найдена подпапка с именем "{folder}".\n'
        f'Найденные имена (первые 30): {all_names}\n'
        f'Если ничего не найдено вообще — проверь что папка доступна "Anyone with the link".\n'
        f'Можно временно указать явный ID: kp.run(folder="ID_подпапки", ...)'
    )


def run(*, folder: Optional[str] = None,
        folder_id: Optional[str] = None,
        langs: str = 'en',
        upload: str = 'api',
        **overrides):
    """Полный пайплайн: скачать → хардсаб → залить.

    Параметры:
        folder    : имя подпапки в drive_parent_id (например '1', '2', '3').
                    Или полный ID/URL Drive-папки.
        folder_id : то же что folder (для обратной совместимости).
        langs     : 'en' | 'en,it' | 'en,it,es' и т.д.
        upload    : 'api' | 'sftp' | 'dm' | 'api,sftp,dm' | 'none'
        **overrides : переопределение любых ключей из DEFAULTS,
                      например api_speed_limit_mbps=5, drive_parent_id='...'

    Примеры:
        kp.run(folder='1', langs='en,it,es')          # подпапка 1 из drive_parent_id
        kp.run(folder='2', langs='en')                # подпапка 2
        kp.run(folder_id='1AbCdEf...', langs='en')    # явный ID/URL
    """
    profile = {**DEFAULTS, **overrides}

    # Разрешаем оба варианта параметра
    folder_arg = folder if folder is not None else folder_id
    if not folder_arg:
        raise RuntimeError('Укажи folder="1" (имя подпапки) или folder_id="ID"')

    real_folder_id = _resolve_drive_folder(folder_arg, profile.get('drive_parent_id'))

    _ensure_dirs()
    # Чистим только рабочие папки (output остаётся между retry, но при run чистим)
    for p in (SRC_DIR, VIDEO_DIR, SUBS_DIR, OUT_DIR, LOG_DIR):
        shutil.rmtree(p, ignore_errors=True)
        p.mkdir(parents=True, exist_ok=True)
    _set_env(profile)
    script = _ensure_script(profile['logo_dir'])

    targets = [t.strip().lower() for t in upload.split(',') if t.strip()]
    if 'none' in targets:
        targets = []

    # Проверяем что нужные секреты на месте — лучше упасть сразу,
    # чем после часа рендера обнаружить что заливать нечем
    if targets and not check_secrets(upload=upload, with_telegram=False, verbose=False):
        print('⚠️  Нет нужных секретов для заливки. Подробности:')
        check_secrets(upload=upload, with_telegram=False, verbose=True)
        raise RuntimeError('Не настроены Kaggle Secrets для выбранного upload. '
                           'Добавь их и запусти снова, или используй upload="none".')

    tg_send(f'🎬 Kaggle: старт\nFolder: <b>{folder_arg}</b>\nLangs: <b>{langs}</b>\nUpload: <b>{upload}</b>', silent=True)
    t_total = time.time()

    # --- 1. Скачивание ---
    print(f'=== 1/4 Downloading from Google Drive ({folder_arg}) ===')
    import gdown
    gdown.download_folder(id=real_folder_id, output=str(SRC_DIR),
                          quiet=False, use_cookies=False)
    for f in SRC_DIR.rglob('*'):
        if not f.is_file():
            continue
        ext = f.suffix.lower()
        if ext in {'.mp4', '.mkv', '.avi', '.mov'}:
            shutil.copy2(f, VIDEO_DIR / f.name)
        elif ext == '.srt':
            shutil.copy2(f, SUBS_DIR / f.name)
    print('\nVideo:'); subprocess.run(['ls', '-la', str(VIDEO_DIR)])
    print('\nSubs:');  subprocess.run(['ls', '-la', str(SUBS_DIR)])

    # --- 2. Хардсаб ---
    print(f'\n=== 2/4 Rendering hardsub for langs: {langs} ===')
    t_render = time.time()
    rc = subprocess.call([
        'python', str(script), '--once',
        '--video-dir',    str(VIDEO_DIR),
        '--subtitle-dir', str(SUBS_DIR),
        '--logo-dir',     profile['logo_dir'],
        '--output-dir',   str(OUT_DIR),
        '--log-dir',      str(LOG_DIR),
        '--dest-langs',   langs,
        '--encoder',      profile['encoder'],
        '--naming',       profile['naming'],
        '--skip-translation',
    ])
    render_dt = time.time() - t_render
    if rc != 0:
        tg_send(f'❌ Kaggle: рендер УПАЛ exit={rc}')
        raise RuntimeError(f'hardsub failed, exit={rc}')

    print('\nOutputs:'); subprocess.run(['ls', '-lh', str(OUT_DIR)])
    outputs = list_outputs()
    tg_send(f'✅ Рендер готов за {render_dt/60:.1f} мин ({len(outputs)} файлов)', silent=True)

    # --- 3. Заливка ---
    print(f'\n=== 3/4 Uploading {len(outputs)} files to: {targets or "NONE"} ===')
    res = _upload(outputs, targets, **profile)

    # --- 4. Итог ---
    total_dt = time.time() - t_total
    lines = [f'🏁 Kaggle: всё готово за <b>{total_dt/60:.1f} мин</b>']
    if 'api' in targets:
        lines.append(f'API: ✅ {res["api_ok"]}/{len(outputs)}')
        if res['api_fail']:
            lines.append('❌ ' + ', '.join(n for n, _ in res['api_fail']))
    if 'sftp' in targets:
        lines.append(f'SFTP: ✅ {res["sftp_ok"]}/{len(outputs)}')
        if res['sftp_fail']:
            lines.append('❌ ' + ', '.join(res['sftp_fail']))
    if 'dm' in targets:
        lines.append(f'DM: ✅ {res.get("dm_ok", 0)}/{len(outputs)}')
        if res.get('dm_fail'):
            lines.append('❌ ' + ', '.join(n for n, _ in res['dm_fail']))
    lines.append('')
    lines.append('⚠️ Нажми <b>Stop Session</b> чтобы освободить GPU квоту!')
    tg_send('\n'.join(lines))

    print('\n=== 4/4 DONE ===')
    for ln in lines:
        print(ln)
    if res['api_fail'] or res['sftp_fail']:
        print('\n[!] Часть файлов не залилась. Используй kp.retry(langs=...)')
    return res


def retry(*, langs: Optional[str] = None, files: Optional[List[str]] = None,
          upload: str = 'api', **overrides):
    """Повторная заливка выбранных языков или конкретных файлов.

    Параметры:
        langs    : 'es' | 'es,it' — какие языки перезалить
        files    : ['video1.es.mp4', ...] — или явно по именам
        upload   : 'api' | 'sftp' | 'api,sftp'
        **overrides : переопределение ключей DEFAULTS
                      (часто полезно api_max_retries=5)
    """
    profile = {**DEFAULTS, **overrides}
    targets = [t.strip().lower() for t in upload.split(',') if t.strip()]

    if files:
        flist = [OUT_DIR / n for n in files if (OUT_DIR / n).exists()]
    else:
        flist = list_outputs(langs)

    print(f'Файлов на повтор: {len(flist)}')
    for f in flist:
        mb = f.stat().st_size / 1024 / 1024
        print(f'  • {f.name}  ({mb:.1f} MB)')

    if not flist:
        print('\nНечего грузить — проверь langs/files и наличие файлов в /kaggle/working/output/')
        return

    tg_send(f'🔁 Kaggle: retry upload\n{len(flist)} файлов\ntargets={upload}', silent=True)
    t0 = time.time()
    res = _upload(flist, targets, **profile)
    dt = time.time() - t0
    msg = [f'🔁 Retry готов за {dt/60:.1f} мин']
    if 'api' in targets:
        msg.append(f'API: ✅ {res["api_ok"]}/{len(flist)}')
        if res['api_fail']:
            msg.append('❌ ' + ', '.join(n for n, _ in res['api_fail']))
    if 'sftp' in targets:
        msg.append(f'SFTP: ✅ {res["sftp_ok"]}/{len(flist)}')
        if res['sftp_fail']:
            msg.append('❌ ' + ', '.join(res['sftp_fail']))
    tg_send('\n'.join(msg))
    print('\n'.join(msg))
    return res


def stop():
