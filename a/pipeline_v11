def _check_secret(name: str, required: bool = True) -> bool:
    sec = _secrets()
    if sec is None: return False
    val = sec.get_secret(name)
    return bool(val and val.strip())

def check_secrets(upload: str = 'api', with_telegram: bool = True, verbose: bool = True) -> bool:
    targets = [t.strip().lower() for t in upload.split(',') if t.strip()]
    needed = []
    optional = []

    if 'api' in targets: needed.append('UPLOAD_API_TOKEN')
    if 'sftp' in targets: needed.append('SFTP_PASS')
    if with_telegram: optional.extend(['TG_BOT_TOKEN', 'TG_CHAT_ID'])

    missing_required = [s for s in needed if not _check_secret(s)]
    missing_optional = [s for s in optional if not _check_secret(s)]

    if verbose:
        if not missing_required and not missing_optional:
            print('✅ Все секреты настроены')
        else:
            print('=== Проверка Секретов Colab ===')
            if missing_required:
                print(f'\n❌ ОБЯЗАТЕЛЬНЫЕ для upload="{upload}":')
                for s in missing_required:
                    print(f'  • {s} — {SECRET_DOCS.get(s, {}).get("why", "—")}')
    return not missing_required

