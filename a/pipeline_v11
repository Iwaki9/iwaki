def tg_send(text: str, silent: bool = False):
    sec = _secrets()
    if sec is None: return
    token = sec.get_secret('TG_BOT_TOKEN')
    chat  = sec.get_secret('TG_CHAT_ID')
    if not token or not chat: return
    try:
        import requests
        requests.post(f'https://api.telegram.org/bot{token}/sendMessage', data={'chat_id': chat, 'text': text, 'parse_mode': 'HTML', 'disable_notification': silent}, timeout=15)
    except Exception: pass

def _sftp_upload(files: Sequence[Path], host, user, port, path, password):
    env = os.environ.copy()
    env.update(SFTP_HOST=host, SFTP_USER=user, SFTP_PORT=port, SFTP_PATH=path, SFTP_PASS=password)
    src_list = ' '.join(f'"{f}"' for f in files)
    cmd = f'lftp -u "$SFTP_USER,$SFTP_PASS" -p "$SFTP_PORT" "sftp://$SFTP_HOST" <<EOF\nset sftp:auto-confirm yes\nmkdir -p $SFTP_PATH\ncd $SFTP_PATH\nmput -P 2 {src_list}\nbye\nEOF'
    rc = subprocess.call(['bash', '-c', cmd], env=env)
    return (len(files), []) if rc == 0 else (0, list(files))

def _api_upload(fpath: Path, server, hostings, token, speed_limit_mbps=2, speed_time_sec=120, max_retries=3):
    size_mb = fpath.stat().st_size / 1024 / 1024
    speed_limit_bps = int(speed_limit_mbps * 1024 * 1024 / 8) if speed_limit_mbps > 0 else 0
    for attempt in range(1, max_retries + 1):
        args = ['curl', '-sS', '--fail-with-body', '-X', 'POST', '--connect-timeout', '30', '-H', f'X-API-Key: {token}', '-F', f'files=@{fpath}']
        if speed_limit_bps > 0: args += ['--speed-limit', str(speed_limit_bps), '--speed-time', str(speed_time_sec)]
        for h in hostings: args += ['-F', f'hostings={h}']
        args += [f'{server}/api/upload']
        r = subprocess.run(args, capture_output=True, text=True, timeout=7200)
        if r.returncode == 0: return True, f'{size_mb/max(1, (time.time()-time.time())):.1f} Mbps'
    return False, 'failed'

def list_outputs(langs: Union[str, Iterable[str], None] = None) -> List[Path]:
    files = sorted(p for p in OUT_DIR.glob('*.mp4') if p.is_file())
    if not langs: return files
    langs_set = {x.strip().lower() for x in (langs.split(',') if isinstance(langs, str) else langs)}
    return [f for f in files if '.' in f.stem and f.stem.rsplit('.', 1)[1].lower() in langs_set]

def _upload(files: Sequence[Path], targets: Sequence[str], **kw):
    res = {'sftp_ok': 0, 'sftp_fail': [], 'api_ok': 0, 'api_fail': []}
    if not files or not targets: return res
    sec = _secrets()
    p = {**DEFAULTS, **kw}
    if 'sftp' in targets:
        ok, fail = _sftp_upload(files, p['sftp_host'], p['sftp_user'], p['sftp_port'], p['sftp_path'], sec.get_secret('SFTP_PASS'))
        res['sftp_ok'] = ok
    if 'api' in targets:
        token = sec.get_secret('UPLOAD_API_TOKEN')
        for f in files:
            ok, _ = _api_upload(f, p['api_server'], p['api_hostings'], token, p['api_speed_limit_mbps'], p['api_speed_time_sec'], p['api_max_retries'])
            if ok: res['api_ok'] += 1
    return res

def _resolve_drive_folder(folder: str, parent_id: Optional[str]) -> str:
    if folder.startswith('http') or (len(folder) >= 20 and '/' not in folder): return folder
    import re, urllib.request
    url = f'https://drive.google.com/drive/folders/{parent_id}'
    req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
    with urllib.request.urlopen(req, timeout=15) as r: html = r.read().decode('utf-8', errors='replace')
    items = {}
    for m in re.finditer(r'<tr[^>]*\sdata-id="([0-9A-Za-z_-]{20,})"[^>]*>(.*?)</tr>', html, re.DOTALL):
        m2 = re.search(r'data-tooltip="([^"]+)"', m.group(2)) or re.search(r'aria-label="([^"]+)"', m.group(2))
        if m2: items[m2.group(1).split(',')[0].replace(' Shared folder','').replace(' Folder','').strip()] = m.group(1)
    return items[folder]

def run(*, folder: Optional[str] = None, folder_id: Optional[str] = None, langs: str = 'en', upload: str = 'api', **overrides):
    profile = {**DEFAULTS, **overrides}
    folder_arg = folder if folder is not None else folder_id
    real_folder_id = _resolve_drive_folder(folder_arg, profile.get('drive_parent_id'))
    _ensure_dirs()
    for p in (SRC_DIR, VIDEO_DIR, SUBS_DIR, OUT_DIR, LOG_DIR): shutil.rmtree(p, ignore_errors=True); p.mkdir(parents=True, exist_ok=True)
    _set_env(profile)
    script = _ensure_script(profile['logo_dir'])
    targets = [t.strip().lower() for t in upload.split(',') if t.strip() if t != 'none']
    tg_send(f'🎬 Colab: старт пайплайна\nFolder: <b>{folder_arg}</b>', silent=True)
    
    print('=== 1/4 Скачивание папки из Google Drive ===')
    import gdown
    # quiet=False активирует наш кастомный красивый перехватчик tqdm
    gdown.download_folder(id=real_folder_id, output=str(SRC_DIR), quiet=False, use_cookies=False)
    print('✅ Скачивание успешно завершено!')

    for f in SRC_DIR.rglob('*'):
        if not f.is_file(): continue
        if f.suffix.lower() in {'.mp4', '.mkv', '.avi', '.mov'}: shutil.copy2(f, VIDEO_DIR / f.name)
        elif f.suffix.lower() == '.srt': shutil.copy2(f, SUBS_DIR / f.name)

    print('\n=== 2/4 Запуск рендера хардсаба ===')
    t_render = time.time()
    cmd = ['python', '-u', str(script), '--once', '--video-dir', str(VIDEO_DIR), '--subtitle-dir', str(SUBS_DIR), '--logo-dir', profile['logo_dir'], '--output-dir', str(OUT_DIR), '--log-dir', str(LOG_DIR), '--dest-langs', langs, '--encoder', profile['encoder'], '--naming', profile['naming'], '--skip-translation']
    
    proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, text=True, bufsize=1)
    while True:
        line = proc.stdout.readline()
        if not line: break
        print(line, end='', flush=True)

    proc.wait()
    if proc.returncode != 0: raise RuntimeError('Рендер упал')
    
    outputs = list_outputs()
    print(f'\n=== 3/4 Заливка видео ({len(outputs)} файлов) ===')
    res = _upload(outputs, targets, **profile)
    print('\n=== 4/4 DONE ===')
    return res

def stop():
    try:
        from google.colab import runtime
        runtime.unassign_bundle()
    except Exception: os._exit(0)
