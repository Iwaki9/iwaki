# Разрешение структуры папок Google Drive
# =========================================================
def _resolve_drive_folder(folder: str, parent_id: Optional[str]) -> str:
    if folder.startswith('http') or (len(folder) >= 20 and '/' not in folder): return folder
    if not parent_id: raise RuntimeError('drive_parent_id не задан в DEFAULTS.')
    import re, urllib.request
    url = f'https://drive.google.com/drive/folders/{parent_id}'
    print(f'🔍 Ищу подпапку "{folder}" в родительской папке {parent_id}...')
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=15) as r:
            html = r.read().decode('utf-8', errors='replace')
    except Exception as e: raise RuntimeError(f'Не удалось получить доступ к Drive: {e}')

    items = {}
    def _clean_name(raw: str) -> str:
        n = raw.strip().split(',', 1)[0].strip()
        for suf in (' Shared folder', ' Shared Folder', ' Folder', ' folder'):
            if n.endswith(suf): n = n[:-len(suf)].rstrip(); break
        return n

    for m in re.finditer(r'<tr[^>]*\sdata-id="([0-9A-Za-z_-]{20,})"[^>]*>(.*?)</tr>', html, re.DOTALL):
        item_id, block = m.group(1), m.group(2)
        m2 = re.search(r'data-tooltip="([^"]+)"', block) or re.search(r'aria-label="([^"]+)"', block)
        if m2:
            name = _clean_name(m2.group(1))
            items[name] = item_id

    if not items:
        for m in re.finditer(r'"([0-9A-Za-z_-]{20,})"[^"]{0,200}?"([^"\\]+)"', html):
            c_id, c_name = m.group(1), _clean_name(m.group(2))
            if len(c_name) < 200 and '<' not in c_name and '\\' not in c_name: items.setdefault(c_name, c_id)

    if folder in items:
        print(f'✅ Найдена подпапка "{folder}": {items[folder]}')
        return items[folder]
    raise RuntimeError(f'Подпапка "{folder}" не найдена. Доступные папки: {list(items.keys())[:30]}')

def run(*, folder: Optional[str] = None, folder_id: Optional[str] = None, langs: str = 'en', upload: str = 'api', **overrides):
    profile = {**DEFAULTS, **overrides}
    folder_arg = folder if folder is not None else folder_id
    if not folder_arg: raise RuntimeError('Укажи folder="имя папки"')

    real_folder_id = _resolve_drive_folder(folder_arg, profile.get('drive_parent_id'))
    _ensure_dirs()
    for p in (SRC_DIR, VIDEO_DIR, SUBS_DIR, OUT_DIR, LOG_DIR):
        shutil.rmtree(p, ignore_errors=True); p.mkdir(parents=True, exist_ok=True)
    _set_env(profile)
    script = _ensure_script(profile['logo_dir'])

    targets = [t.strip().lower() for t in upload.split(',') if t.strip() if t != 'none']
    tg_send(f'🎬 Colab: старт пайплайна\nFolder: <b>{folder_arg}</b>\nLangs: <b>{langs}</b>\nUpload: <b>{upload}</b>', silent=True)
    t_total = time.time()

    print(f'=== 1/4 Скачивание папки из Google Drive ===')
    import gdown
    gdown.download_folder(id=real_folder_id, output=str(SRC_DIR), quiet=False, use_cookies=False)
    for f in SRC_DIR.rglob('*'):
        if not f.is_file(): continue
        ext = f.suffix.lower()
        if ext in {'.mp4', '.mkv', '.avi', '.mov'}: shutil.copy2(f, VIDEO_DIR / f.name)
        elif ext == '.srt': shutil.copy2(f, SUBS_DIR / f.name)

    print(f'\n=== 2/4 Запуск рендера хардсаба ===')
    t_render = time.time()
    rc = subprocess.call([
        'python', str(script), '--once',
        '--video-dir',    str(VIDEO_DIR),
        '--subtitle-dir', str(SUBS_DIR),
        '--logo-dir',     profile['logo_dir'],
        '--output-dir',   str(OUT_DIR),
        '--log-dir',      str(LOG_DIR),
        '--dest-langs',   langs,
        '--encoder',      profile['encoder'],
        '--naming',       profile['naming'],
        '--skip-translation',
    ])
    if rc != 0: tg_send('❌ Colab: Рендер упал!'); raise RuntimeError(f'Hardsub failed, exit={rc}')
    outputs = list_outputs()
    tg_send(f'✅ Рендер готов за {(time.time()-t_render)/60:.1f} мин ({len(outputs)} файлов)', silent=True)

    print(f'\n=== 3/4 Заливка на сервера ===')
    res = _upload(outputs, targets, **profile)

    total_dt = (time.time() - t_total) / 60
    lines = [f'🏁 Colab: Всё готово за <b>{total_dt:.1f} мин</b>']
    if 'api' in targets: lines.append(f'API: ✅ {res["api_ok"]}/{len(outputs)}')
    if 'sftp' in targets: lines.append(f'SFTP: ✅ {res["sftp_ok"]}/{len(outputs)}')
    tg_send('\n'.join(lines))
    print('\n=== 4/4 DONE ===')
    return res

def retry(*, langs: Optional[str] = None, files: Optional[List[str]] = None, upload: str = 'api', **overrides):
    profile = {**DEFAULTS, **overrides}
    targets = [t.strip().lower() for t in upload.split(',') if t.strip()]
    flist = [OUT_DIR / n for n in files if (OUT_DIR / n).exists()] if files else list_outputs(langs)
    print(f'Файлов на повтор: {len(flist)}')
    return _upload(flist, targets, **profile)

