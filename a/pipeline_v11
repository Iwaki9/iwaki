                await upload_btn.click()
            chooser = await fc.value
            await chooser.set_files(file_path)

        print('  Файл передан, ждём редактор (15с)...')
        await asyncio.sleep(15)

        await page.locator('input#title').fill(title[:255])
        await page.locator('textarea#description').fill(description[:3000])

        print(f'  Категория: {category}')
        cat_block = page.locator('label', has_text='Category').locator('xpath=../..')
        select_box = cat_block.locator('.ant-select-selector').first
        await select_box.click(force=True)
        await asyncio.sleep(1.5)
        found = False
        for _ in range(25):
            active = page.locator('.ant-select-item-option-active')
            if await active.count() > 0:
                t = await active.first.get_attribute('title')
                if t == category:
                    await page.keyboard.press('Enter')
                    found = True
                    break
            await page.keyboard.press('ArrowDown')
            await asyncio.sleep(0.3)
        if not found:
            raise RuntimeError(f'Не нашёл категорию: {category}')

        await asyncio.sleep(2)
        await page.locator("button:has-text('Next')").first.click(force=True)
        await asyncio.sleep(3)
        kids_val = 'true' if kids else 'false'
        await page.locator(f"input[name='is_created_for_kids'][value='{kids_val}']").locator('..').click(force=True)
        await page.locator("button:has-text('Next')").first.click(force=True)
        await asyncio.sleep(3)
        await page.locator(f"input[name='visibility'][value='{visibility}']").locator('..').click(force=True)
        await asyncio.sleep(1)

        print('  Ждём обработку файла на серверах DM (до 2ч)...')
        max_wait = 7200
        waited = 0
        while waited < max_wait:
            badges = page.locator("div[class*='infoText']")
            cnt = await badges.count()
            uploading = False
            for i in range(cnt):
                t = (await badges.nth(i).inner_text()).lower()
                if 'failed' in t or 'error' in t:
                    await page.screenshot(path='/kaggle/working/dm_failed.png', full_page=True)
                    raise RuntimeError(f'DM отклонил: "{t}" (скрин: /kaggle/working/dm_failed.png)')
                if 'uploading' in t or 'processing' in t:
                    print(f'  Статус: {t} ({waited}s/{max_wait}s)')
                    uploading = True
                    break
            if uploading:
                await asyncio.sleep(5)
                waited += 5
            else:
                break

        await asyncio.sleep(5)
        save_btn = page.locator("button:has-text('Save')").first
        if await save_btn.is_enabled():
            await save_btn.click(force=True)
            print(f'  ✅ ОПУБЛИКОВАНО: {title}')
        else:
            raise RuntimeError('Кнопка Save неактивна — сбой DM')
        await asyncio.sleep(5)
        await browser.close()


def _dm_install_deps_once():
    """Ставит playwright + chromium если ещё не стоит. Идемпотентно."""
    marker = WORKING / '.playwright_installed'
    if marker.exists():
        return
    print('=== Установка playwright + chromium (один раз) ===')
    subprocess.run(['pip', 'install', '-q', 'playwright', 'nest_asyncio'], check=True)
    subprocess.run(['playwright', 'install', 'chromium'], check=True,
                   stdout=subprocess.DEVNULL)
    subprocess.run(['playwright', 'install-deps'],
                   stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    marker.touch()
    print('✅ Playwright готов')


def _run_async(coro):
    """
    Запускает корутину как в обычном Python, так и внутри Jupyter,
    где уже крутится event loop.
    """
    try:
        loop = asyncio.get_event_loop()
    except RuntimeError:
        loop = None

    if loop is not None and loop.is_running():
        # Мы внутри jupyter / другого работающего loop'а
        try:
            import nest_asyncio
            nest_asyncio.apply()
        except ImportError:
            subprocess.run(['pip', 'install', '-q', 'nest_asyncio'], check=True)
            import nest_asyncio
            nest_asyncio.apply()
        return loop.run_until_complete(coro)
    else:
        return asyncio.run(coro)


def upload_dm(*, lang: Optional[str] = None,
              files: Optional[List[str]] = None,
              title: Optional[str] = None,
              description: Optional[str] = None,
              category: Optional[str] = None,
              visibility: Optional[str] = None,
              kids: Optional[bool] = None,
              cookies_path: Optional[str] = None) -> dict:
    """
    Загрузить файл(ы) из /kaggle/working/output на Dailymotion.

    Параметры:
        lang        : 'en' | 'it' | 'es' — взять *.<lang>.mp4 из output
        files       : ['Video.en.mp4'] — явный список (имя или абсолютный путь)
        title       : переопределить title (иначе генерируется из имени файла)
        description : текст описания (по умолчанию из DM_DEFAULTS)
        category    : категория DM (по умолчанию 'TV')
        visibility  : 'private' | 'public'
        kids        : контент для детей (по умолчанию False)
        cookies_path: путь к JSON с куками (по умолчанию /kaggle/working/cookies.json)
    """
    _dm_install_deps_once()

    p = {**DM_DEFAULTS}
    if cookies_path: p['cookies_path'] = cookies_path
    if category:     p['category']     = category
    if description:  p['description']  = description
    if visibility:   p['visibility']   = visibility
    if kids is not None: p['kids']     = kids

    # Собираем список файлов
    if files:
        flist = []
        for x in files:
            path = Path(x)
            if not path.is_absolute():
                path = OUT_DIR / x
            if path.exists():
                flist.append(path)
            else:
                print(f'⚠️  Файл не найден: {path}')
    elif lang:
        flist = list_outputs(lang)
    else:
        flist = list_outputs()

    if not flist:
        print('Нет файлов для загрузки на DM. Укажи lang= или files=.')
        return {'dm_ok': 0, 'dm_fail': []}

    print(f'DM: {len(flist)} файл(ов) к заливке')
    for f in flist:
        sz = f.stat().st_size / 1024 / 1024
        print(f'  • {f.name}  ({sz:.1f} MB)')

    tg_send(f'📺 DM: старт заливки {len(flist)} файлов', silent=True)
    res = {'dm_ok': 0, 'dm_fail': []}
    t0 = time.time()
    for f in flist:
        # обрезаем если > 2ч
        actual = _trim_video_if_needed(str(f))
        # title
        gen_title = title or _dm_make_title(Path(actual).stem.replace('_trimmed', ''))
        try:
            _run_async(_dm_upload_one_async(
                file_path=actual,
                title=gen_title,
                description=p['description'],
                category=p['category'],
                cookies_file=p['cookies_path'],
                visibility=p['visibility'],
                kids=p['kids'],
            ))
            res['dm_ok'] += 1
        except Exception as e:
            print(f'❌ DM FAIL для {f.name}: {e}')
            res['dm_fail'].append((f.name, str(e)))

    dt = time.time() - t0
    msg = [f'📺 DM готово за {dt/60:.1f} мин  ✅ {res["dm_ok"]}/{len(flist)}']
    if res['dm_fail']:
        msg.append('❌ ' + ', '.join(n for n, _ in res['dm_fail']))
    tg_send('\n'.join(msg))
    print('\n'.join(msg))
    return res
