        import requests
        requests.post(f'https://api.telegram.org/bot{token}/sendMessage', data={'chat_id': chat, 'text': text, 'parse_mode': 'HTML', 'disable_notification': silent}, timeout=15)
    except Exception as e: print(f'[tg warn] {e}')

def _sftp_upload(files: Sequence[Path], host, user, port, path, password):
    env = os.environ.copy()
    env.update(SFTP_HOST=host, SFTP_USER=user, SFTP_PORT=port, SFTP_PATH=path, SFTP_PASS=password)
    src_list = ' '.join(f'"{f}"' for f in files)
    cmd = f'lftp -u "$SFTP_USER,$SFTP_PASS" -p "$SFTP_PORT" "sftp://$SFTP_HOST" <<EOF\nset sftp:auto-confirm yes\nmkdir -p $SFTP_PATH\ncd $SFTP_PATH\nmput -P 2 {src_list}\nbye\nEOF'
    rc = subprocess.call(['bash', '-c', cmd], env=env)
    return (len(files), []) if rc == 0 else (0, list(files))

def _api_upload(fpath: Path, server, hostings, token, speed_limit_mbps=2, speed_time_sec=120, max_retries=3):
    size_mb = fpath.stat().st_size / 1024 / 1024
    speed_limit_bps = int(speed_limit_mbps * 1024 * 1024 / 8) if speed_limit_mbps > 0 else 0
    last = ''
    for attempt in range(1, max_retries + 1):
        t0 = time.time()
        args = ['curl', '-sS', '--fail-with-body', '-X', 'POST', '--connect-timeout', '30', '-H', f'X-API-Key: {token}', '-F', f'files=@{fpath}']
        if speed_limit_bps > 0: args += ['--speed-limit', str(speed_limit_bps), '--speed-time', str(speed_time_sec)]
        for h in hostings: args += ['-F', f'hostings={h}']
        args += [f'{server}/api/upload']
        try:
            r = subprocess.run(args, capture_output=True, text=True, timeout=7200)
        except subprocess.TimeoutExpired: return False, 'timeout'
        dt = time.time() - t0
        speed = (size_mb * 8) / dt if dt > 0 else 0

        if r.returncode == 0: return True, f'{speed:.1f} Mbps'
        last = f'exit {r.returncode}'
        time.sleep(5)
    return False, last

def list_outputs(langs: Union[str, Iterable[str], None] = None) -> List[Path]:
    files = sorted(p for p in OUT_DIR.glob('*.mp4') if p.is_file())
    if not langs: return files
    langs_set = {x.strip().lower() for x in (langs.split(',') if isinstance(langs, str) else langs)}
    out = []
    for f in files:
        stem = f.stem
        if '.' in stem:
            _, lang = stem.rsplit('.', 1)
            if lang.lower() in langs_set: out.append(f)
    return out

def _upload(files: Sequence[Path], targets: Sequence[str], **kw):
    res = {'sftp_ok': 0, 'sftp_fail': [], 'api_ok': 0, 'api_fail': []}
    if not files or not targets: return res
    sec = _secrets()
    p = {**DEFAULTS, **kw}

    if 'sftp' in targets:
        pw = sec.get_secret('SFTP_PASS')
        ok, fail = _sftp_upload(files, p['sftp_host'], p['sftp_user'], p['sftp_port'], p['sftp_path'], pw)
        res['sftp_ok'] = ok; res['sftp_fail'] = [f.name for f in fail]

    if 'api' in targets:
        token = sec.get_secret('UPLOAD_API_TOKEN')
        for i, f in enumerate(files, 1):
            ok, info = _api_upload(f, p['api_server'], p['api_hostings'], token, p['api_speed_limit_mbps'], p['api_speed_time_sec'], p['api_max_retries'])
            if ok: res['api_ok'] += 1
            else: res['api_fail'].append((f.name, info))
    return res

def _resolve_drive_folder(folder: str, parent_id: Optional[str]) -> str:
    if folder.startswith('http') or (len(folder) >= 20 and '/' not in folder): return folder
    if not parent_id: raise RuntimeError('drive_parent_id не задан.')
    import re, urllib.request
    url = f'https://drive.google.com/drive/folders/{parent_id}'
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=15) as r:
            html = r.read().decode('utf-8', errors='replace')
    except Exception as e: raise RuntimeError(f'Ошибка сканирования: {e}')
    
    items = {}
    for m in re.finditer(r'<tr[^>]*\sdata-id="([0-9A-Za-z_-]{20,})"[^>]*>(.*?)</tr>', html, re.DOTALL):
        item_id, block = m.group(1), m.group(2)
        m2 = re.search(r'data-tooltip="([^"]+)"', block) or re.search(r'aria-label="([^"]+)"', block)
        if m2:
            name = m2.group(1).split(',')[0].replace(' Shared folder','').replace(' Folder','').strip()
            items[name] = item_id
            
    if folder in items: return items[folder]
    raise RuntimeError(f'Подпапка "{folder}" не найдена в каталоге Google Drive.')

def run(*, folder: Optional[str] = None, folder_id: Optional[str] = None, langs: str = 'en', upload: str = 'api', **overrides):
    profile = {**DEFAULTS, **overrides}
    folder_arg = folder if folder is not None else folder_id
    if not folder_arg: raise RuntimeError('Укажите параметр folder="номер"')

    real_folder_id = _resolve_drive_folder(folder_arg, profile.get('drive_parent_id'))
    _ensure_dirs()
    for p in (SRC_DIR, VIDEO_DIR, SUBS_DIR, OUT_DIR, LOG_DIR):
        shutil.rmtree(p, ignore_errors=True); p.mkdir(parents=True, exist_ok=True)
    _set_env(profile)
    script = _ensure_script(profile['logo_dir'])

    targets = [t.strip().lower() for t in upload.split(',') if t.strip() if t != 'none']
    tg_send(f'🎬 Colab: старт пайплайна\nFolder: <b>{folder_arg}</b>\nLangs: <b>{langs}</b>', silent=True)
    t_total = time.time()

    print('=== 1/4 Скачивание папки из Google Drive ===')
    print('📥 Загрузка запущена (тихий режим, без спама строками)...')
    import gdown
    # Индикатор отключен ради предотвращения лавинного спама строками в Colab
    gdown.download_folder(id=real_folder_id, output=str(SRC_DIR), quiet=True, use_cookies=False)
    print('✅ Скачивание успешно завершено!')

    for f in SRC_DIR.rglob('*'):
        if not f.is_file(): continue
        ext = f.suffix.lower()
        if ext in {'.mp4', '.mkv', '.avi', '.mov'}: shutil.copy2(f, VIDEO_DIR / f.name)
        elif ext == '.srt': shutil.copy2(f, SUBS_DIR / f.name)

    print('\n=== 2/4 Запуск рендера хардсаба ===')
    t_render = time.time()
    # Флаг '-u' принудительно отключает буферизацию вывода Python!
    rc = subprocess.call([
        'python', '-u', str(script), '--once',
        '--video-dir',    str(VIDEO_DIR),
        '--subtitle-dir', str(SUBS_DIR),
        '--logo-dir',     profile['logo_dir'],
        '--output-dir',   str(OUT_DIR),
        '--log-dir',      str(LOG_DIR),
        '--dest-langs',   langs,
        '--encoder',      profile['encoder'],
        '--naming',       profile['naming'],
        '--skip-translation',
    ])
    if rc != 0: tg_send('❌ Colab: рендер завершился ошибкой'); raise RuntimeError('Рендер упал')
    
    outputs = list_outputs()
    tg_send(f'✅ Рендер готов за {(time.time()-t_render)/60:.1f} мин', silent=True)

    print('\n=== 3/4 Заливка видео ===')
    res = _upload(outputs, targets, **profile)

    total_dt = (time.time() - t_total) / 60
    lines = [f'🏁 Colab: Пайплайн выполнен за <b>{total_dt:.1f} мин</b>', f'API: ✅ {res.get("api_ok",0)}, SFTP: ✅ {res.get("sftp_ok",0)}']
    tg_send('\n'.join(lines))
    print('\n'.join(lines))
    return res

def stop():
    try:
        from google.colab import runtime
        runtime.unassign_bundle()
    except Exception:
        os._exit(0)
