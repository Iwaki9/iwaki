def _check_secret(name: str, required: bool = True) -> bool:
    """Возвращает True если секрет существует и заполнен."""
    sec = _secrets()
    if sec is None:
        return False
    try:
        val = sec.get_secret(name)
        return bool(val and val.strip())
    except Exception:
        return False


