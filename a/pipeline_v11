def _secrets():
    try:
        from google.colab import userdata
        class ColabSecretsWrapper:
            def get_secret(self, name):
                try: return userdata.get(name)
                except Exception: return None
        return ColabSecretsWrapper()
    except Exception: return None

def _check_secret(name: str) -> bool:
    sec = _secrets()
    if sec is None: return False
    val = sec.get_secret(name)
    return bool(val and val.strip())

def check_secrets(upload: str = 'api', with_telegram: bool = True, verbose: bool = True) -> bool:
    targets = [t.strip().lower() for t in upload.split(',') if t.strip()]
    needed = []
    if 'api' in targets: needed.append('UPLOAD_API_TOKEN')
    if 'sftp' in targets: needed.append('SFTP_PASS')
    missing_required = [s for s in needed if not _check_secret(s)]
    return not missing_required

