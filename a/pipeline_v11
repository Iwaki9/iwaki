DM_DEFAULTS = {
    'cookies_path': '/content/cookies.json',
    'category':     'TV',
    'description':  'Автоматическая загрузка из Google Colab',
    'visibility':   'private',
    'kids':         False,
}

LANG_NAMES = {'en': 'english', 'it': 'italian', 'es': 'spanish', 'ru': 'russian', 'fr': 'french', 'de': 'german', 'tr': 'turkish'}

def save_dm_cookies(raw_cookies_text: str, out_path: str = None) -> str:
    import json, re
    out_path = out_path or DM_DEFAULTS['cookies_path']
    cleaned = re.sub(r'\[([^\]]+)\]\([^\)]+\)', r'\1', raw_cookies_text)
    cleaned = re.sub(r'\{"name":"g_state".*?(?=\{"name"|\}\])', '', cleaned).replace(',,', ',').replace('[,', '[').replace(',]', ']').strip()
    parsed = json.loads(cleaned)
    for c in parsed:
        for k in ('storeId', 'firstPartyDomain', 'partitionKey'): c.pop(k, None)
    Path(out_path).parent.mkdir(parents=True, exist_ok=True)
    with open(out_path, 'w', encoding='utf-8') as f: json.dump(parsed, f, indent=4)
    print(f'✅ Cookies сохранены: {out_path}')
    return out_path

def _dm_make_title(file_stem: str) -> str:
    import re
    match = re.match(r'^(?P<base>.+)\.(?P<lang>[a-zA-Z]{2,3})$', file_stem)
    base, lang_code = (match.group('base'), match.group('lang').lower()) if match else (file_stem, '')
    lang_name = LANG_NAMES.get(lang_code, lang_code)
    ep_num, show = None, base

    m = re.search(r'(\d+)\.\s*Bölüm', base, re.IGNORECASE) or re.search(r'Bölüm\s*(\d+)', base, re.IGNORECASE) or re.search(r'(?:Episode|Ep)\.?\s*(\d+)', base, re.IGNORECASE) or re.search(r'S\d+E(\d+)', base, re.IGNORECASE) or re.search(r'[｜|]\s*(\d+)\s*\.', base)
    if m:
        ep_num = m.group(1)
        show = base[:m.start()].strip() if 'Bölüm' in m.group(0) or '｜' in m.group(0) else (base[:m.start()] + base[m.end():]).strip()

    show = re.sub(r'[\s\.\-_｜|]+$', '', show).strip()
    parts = [show]
    if ep_num: parts.append(f'episode {ep_num}')
    if lang_name: parts.append(f'{lang_name} subtitles')
    return ' '.join(parts).strip()[:255]

def _get_video_duration(path: str) -> float:
    try:
        r = subprocess.run(['ffprobe', '-v', 'error', '-show_entries', 'format=duration', '-of', 'default=noprint_wrappers=1:nokey=1', path], capture_output=True, text=True)
        return float(r.stdout.strip())
    except Exception: return 0.0

def _trim_video_if_needed(path: str, limit_sec: int = 7200) -> str:
    import random
    dur = _get_video_duration(path)
    if dur <= limit_sec: return path
    target = 7140 + random.randint(10, 40)
    p = Path(path)
    out = p.with_name(f'{p.stem}_trimmed{p.suffix}')
    print(f'✂️ Видео длиннее 2 часов ({int(dur)}s) -> режем до {target}s')
    subprocess.run(['ffmpeg', '-y', '-i', path, '-t', str(target), '-c', 'copy', str(out)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return str(out) if out.exists() else path

async def _dm_upload_one_async(file_path: str, title: str, description: str, category: str, cookies_file: str, visibility: str, kids: bool):
    import json
    from playwright.async_api import async_playwright
    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True, args=['--no-sandbox', '--disable-dev-shm-usage', '--disable-gpu', '--single-process'])
        context = await browser.new_context(viewport={'width': 1280, 'height': 720})
        with open(cookies_file) as f: raw = json.load(f)
        await context.add_cookies([{'name': c['name'], 'value': c['value'], 'domain': c['domain'], 'path': c['path']} for c in raw])
        page = await context.new_page()
        print(f'→ Подключаюсь к DM для "{title}"...')
        await page.goto('https://www.dailymotion.com/partner/media/video?upload=true', timeout=60000)
        await page.wait_for_load_state('networkidle')
        await asyncio.sleep(5)

        if 'login' in page.url or 'signin' in page.url: raise RuntimeError('Cookies протухли!')

        file_input = page.locator("input[type='file']")
        if await file_input.count() > 0: await file_input.first.set_input_files(file_path)
        else:
            async with page.expect_file_chooser() as fc: await page.locator('button, div').filter(has_text='Select files').first.click()
            await (await fc.value).set_files(file_path)

        await asyncio.sleep(15)
        await page.locator('input#title').fill(title[:255])
        await page.locator('textarea#description').fill(description[:3000])

        cat_block = page.locator('label', has_text='Category').locator('xpath=../..')
        await cat_block.locator('.ant-select-selector').first.click(force=True)
        await asyncio.sleep(1.5)
        found = False
        for _ in range(25):
            active = page.locator('.ant-select-item-option-active')
            if await active.count() > 0 and (await active.first.get_attribute('title')) == category:
                await page.keyboard.press('Enter'); found = True; break
            await page.keyboard.press('ArrowDown'); await asyncio.sleep(0.3)
        if not found: raise RuntimeError(f'Не найдена категория: {category}')

        await asyncio.sleep(2)
        await page.locator("button:has-text('Next')").first.click(force=True)
        await asyncio.sleep(3)
        await page.locator(f"input[name='is_created_for_kids'][value='{'true' if kids else 'false'}']").locator('..').click(force=True)
        await page.locator("button:has-text('Next')").first.click(force=True)
        await asyncio.sleep(3)
        await page.locator(f"input[name='visibility'][value='{visibility}']").locator('..').click(force=True)

        print('  Ожидание обработки на DM (до 2 часов)...')
        waited, max_wait = 0, 7200
        while waited < max_wait:
            badges = page.locator("div[class*='infoText']")
            uploading = False
            for i in range(await badges.count()):
                t = (await badges.nth(i).inner_text()).lower()
                if 'failed' in t or 'error' in t:
                    await page.screenshot(path='/content/dm_failed.png', full_page=True)
                    raise RuntimeError(f'DM отклонил файл: {t}')
                if 'uploading' in t or 'processing' in t: uploading = True; break
            if uploading: await asyncio.sleep(5); waited += 5
            else: break

        await asyncio.sleep(5)
        save_btn = page.locator("button:has-text('Save')").first
        if await save_btn.is_enabled():
            await save_btn.click(force=True); print(f'  ✅ ОПУБЛИКОВАНО: {title}')
        else: raise RuntimeError('Кнопка Save заблокирована.')
        await asyncio.sleep(5); await browser.close()

def _dm_install_deps_once():
    marker = WORKING / '.playwright_installed'
    if marker.exists(): return
    print('=== Установка Playwright & Chromium ===')
    subprocess.run(['pip', 'install', '-q', 'playwright', 'nest_asyncio'], check=True)
    subprocess.run(['playwright', 'install', 'chromium'], check=True)
    subprocess.run(['playwright', 'install-deps'], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    marker.touch()

def _run_async(coro):
    import nest_asyncio
    nest_asyncio.apply()
    return asyncio.get_event_loop().run_until_complete(coro)

def upload_dm(*, lang: Optional[str] = None, files: Optional[List[str]] = None, title: Optional[str] = None, description: Optional[str] = None, category: Optional[str] = None, visibility: Optional[str] = None, kids: Optional[bool] = None, cookies_path: Optional[str] = None) -> dict:
    _dm_install_deps_once()
    p = {**DM_DEFAULTS}
    if cookies_path: p['cookies_path'] = cookies_path
    if category: p['category'] = category
    if description: p['description'] = description
    if visibility: p['visibility'] = visibility
    if kids is not None: p['kids'] = kids

    flist = [Path(x) if Path(x).is_absolute() else OUT_DIR / x for x in files] if files else (list_outputs(lang) if lang else list_outputs())
    flist = [f for f in flist if f.exists()]
    if not flist: print('Нет файлов для загрузки на DM.'); return {'dm_ok': 0, 'dm_fail': []}

    tg_send(f'📺 DM: старт загрузки {len(flist)} файлов', silent=True)
    res = {'dm_ok': 0, 'dm_fail': []}
    for f in flist:
        actual = _trim_video_if_needed(str(f))
        gen_title = title or _dm_make_title(Path(actual).with_suffix('').name.replace('_trimmed', ''))
        try:
            _run_async(_dm_upload_one_async(actual, gen_title, p['description'], p['category'], p['cookies_path'], p['visibility'], p['kids']))
            res['dm_ok'] += 1
        except Exception as e:
            print(f'❌ DM FAIL для {f.name}: {e}')
            res['dm_fail'].append((f.name, str(e)))
    return res
