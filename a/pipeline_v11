}


def _dm_clean_cookies_text(raw: str) -> str:
    """Чистит сырой текст кук из браузерного расширения, возвращает валидный JSON-текст."""
    import re as _re
    cleaned = _re.sub(r'\[([^\]]+)\]\([^\)]+\)', r'\1', raw)
    cleaned = _re.sub(r'\{"name":"g_state".*?(?=\{"name"|\}\])', '', cleaned)
    cleaned = cleaned.replace(',,', ',').replace('[,', '[').replace(',]', ']')
    return cleaned.strip()


def save_dm_cookies(raw_cookies_text: str, out_path: str = None) -> str:
    """
    Принимает сырой текст кук (как из расширения Cookie Editor),
    чистит и сохраняет в JSON-файл.
    Возвращает путь к файлу.
    """
    import json as _json
    out_path = out_path or DM_DEFAULTS['cookies_path']
    cleaned = _dm_clean_cookies_text(raw_cookies_text)
    try:
        parsed = _json.loads(cleaned)
    except _json.JSONDecodeError as e:
        err_pos = e.pos
        start = max(0, err_pos - 30)
        end = min(len(cleaned), err_pos + 30)
        raise RuntimeError(
            f'Не могу разобрать cookies JSON: {e}\n'
            f'Контекст: ...{cleaned[start:end]}...'
        )
    for c in parsed:
        c.pop('storeId', None)
        c.pop('firstPartyDomain', None)
        c.pop('partitionKey', None)
    Path(out_path).parent.mkdir(parents=True, exist_ok=True)
    with open(out_path, 'w', encoding='utf-8') as f:
        _json.dump(parsed, f, indent=4)
    print(f'✅ Cookies сохранены: {out_path} ({len(parsed)} штук)')
    return out_path


def _dm_make_title(file_stem: str) -> str:
    """
    'Eşref Rüya 46. Bölüm.en' -> 'Eşref Rüya episode 46 english subtitles'
    Логика: убираем '<номер>. Bölüm' (или другой маркер серии), берём язык из хвоста.
    """
    import re as _re
    # отрезать языковой хвост .en/.it/.es
    lang_match = _re.match(r'^(?P<base>.+)\.(?P<lang>[a-zA-Z]{2,3})$', file_stem)
    if lang_match:
        base = lang_match.group('base')
        lang_code = lang_match.group('lang').lower()
    else:
        base = file_stem
        lang_code = ''

    lang_name = LANG_NAMES.get(lang_code, lang_code)

    # Ищем номер серии: "46. Bölüm" / "Bölüm 46" / "Episode 46" / "S01E46" / "｜ 2."
    ep_num = None
    show = base

    # Турецкий: "46. Bölüm"
    m = _re.search(r'(\d+)\.\s*Bölüm', base, _re.IGNORECASE)
    if m:
        ep_num = m.group(1)
        show = base[:m.start()].strip()

    # "Bölüm 46"
    if ep_num is None:
        m = _re.search(r'Bölüm\s*(\d+)', base, _re.IGNORECASE)
        if m:
            ep_num = m.group(1)
            show = (base[:m.start()] + base[m.end():]).strip()

    # "Episode 46" / "Ep 46"
    if ep_num is None:
        m = _re.search(r'(?:Episode|Ep)\.?\s*(\d+)', base, _re.IGNORECASE)
        if m:
            ep_num = m.group(1)
            show = (base[:m.start()] + base[m.end():]).strip()

    # S01E46
    if ep_num is None:
        m = _re.search(r'S\d+E(\d+)', base, _re.IGNORECASE)
        if m:
            ep_num = m.group(1)
            show = (base[:m.start()] + base[m.end():]).strip()

    # "｜ 2." (полноширинный | + номер)
    if ep_num is None:
        m = _re.search(r'[｜|]\s*(\d+)\s*\.', base)
        if m:
            ep_num = m.group(1)
            show = (base[:m.start()] + base[m.end():]).strip()

    # Хвостовые точки/пробелы/тире
    show = _re.sub(r'[\s\.\-_｜|]+$', '', show).strip()

    parts = [show]
    if ep_num:
        parts.append(f'episode {ep_num}')
    if lang_name:
        parts.append(f'{lang_name} subtitles')
    title = ' '.join(parts).strip()
    return title[:255]


def _get_video_duration(path: str) -> float:
    try:
        r = subprocess.run(
            ['ffprobe', '-v', 'error', '-show_entries', 'format=duration',
             '-of', 'default=noprint_wrappers=1:nokey=1', path],
            capture_output=True, text=True,
        )
        return float(r.stdout.strip())
    except Exception:
        return 0.0


def _trim_video_if_needed(path: str, limit_sec: int = 7200) -> str:
    """DM не принимает видео > 2ч. Если длиннее — режем без перекодирования."""
    import random as _rnd
    dur = _get_video_duration(path)
    if dur <= limit_sec:
        return path
    target = 7140 + _rnd.randint(10, 40)
    p = Path(path)
    out = p.with_name(f'{p.stem}_trimmed{p.suffix}')
    print(f'✂️  Видео {int(dur)}s длиннее лимита {limit_sec}s → режем до {target}s')
    subprocess.run(
        ['ffmpeg', '-y', '-i', path, '-t', str(target), '-c', 'copy', str(out)],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
    )
    if out.exists():
        return str(out)
    print('❌ Ошибка обрезки, используем оригинал')
    return path


async def _dm_upload_one_async(file_path: str, title: str, description: str,
                               category: str, cookies_file: str,
                               visibility: str = 'private', kids: bool = False):
