# colab_pipeline.py — Полная исправленная версия под Colab
from __future__ import annotations
import os
import re
import shutil
import subprocess
import urllib.request
from pathlib import Path
from typing import Optional

WORKING   = Path('/content')
SRC_DIR   = WORKING / 'src'
VIDEO_DIR = WORKING / 'video'
SUBS_DIR  = WORKING / 'subs'
OUT_DIR   = WORKING / 'output'
LOG_DIR   = WORKING / 'logs'

FFMPEG_BIN  = WORKING / 'ffmpeg-bin' / 'bin' / 'ffmpeg'

DEFAULTS = {
    'encoder': 'nvenc',
    'naming': 'workflow2',
    'render_parallel': 2,
    'ffmpeg_threads': 'auto',
    'gpu_overlay': False,
    'drive_parent_id': '1DoCzjatQBGQmUEycPRc5nYZPngRfCIfR',
    'logo_dir': '/content/logos',
    'logo_en': '/content/logos/logo riki.png',
    'logo_it': '/content/logos/logo.png',
    'logo_es': '/content/logos/logo.png',
}

def ensure_dirs():
    for p in (SRC_DIR, VIDEO_DIR, SUBS_DIR, OUT_DIR, LOG_DIR):
        p.mkdir(parents=True, exist_ok=True)

def set_env(profile: dict):
    os.environ['PATH'] = f'{FFMPEG_BIN.parent}:' + os.environ.get('PATH', '')
    os.environ['FFMPEG_PATH'] = str(FFMPEG_BIN)
    os.environ['FFPROBE_PATH'] = str(FFMPEG_BIN).replace('ffmpeg', 'ffprobe')

def download_logos():
    os.makedirs('/content/logos', exist_ok=True)
    urls = {
        '/content/logos/logo riki.png': 'https://raw.githubusercontent.com/Iwaki9/iwaki/refs/heads/master/a/logo%20riki.png',
        '/content/logos/logo.png': 'https://raw.githubusercontent.com/Iwaki9/iwaki/refs/heads/master/a/logo.png'
    }
    for path, url in urls.items():
        if not os.path.exists(path):
            subprocess.run(['wget', '-q', '-O', path, url], check=True)

def setup():
    print("=== SETUP (Colab) ===")
    ensure_dirs()
    download_logos()

    # === Надёжная установка ffmpeg ===
    if not FFMPEG_BIN.exists():
        print("Устанавливаем ffmpeg с NVENC...")
        success = False
        try:
            subprocess.run(['bash', '-c', '''
                rm -rf /content/ffmpeg-bin /tmp/ffmpeg.tar.xz
                wget -q https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-n8.1-latest-linux64-gpl-n8.1.tar.xz -O /tmp/ffmpeg.tar.xz
                tar -xf /tmp/ffmpeg.tar.xz -C /content
                mv /content/ffmpeg-n8.1* /content/ffmpeg-bin 2>/dev/null || true
            '''], check=True, timeout=300)
            if FFMPEG_BIN.exists():
                success = True
        except:
            pass

        if not success:
            print("⚠️ BtbN не скачался — используем системный ffmpeg")
            os.makedirs('/content/ffmpeg-bin/bin', exist_ok=True)
            subprocess.run(['ln', '-sf', '/usr/bin/ffmpeg',  '/content/ffmpeg-bin/bin/ffmpeg'], check=False)
            subprocess.run(['ln', '-sf', '/usr/bin/ffprobe', '/content/ffmpeg-bin/bin/ffprobe'], check=False)

    # Обновляем переменные окружения
    set_env(DEFAULTS)
    os.environ['PATH'] = f'{FFMPEG_BIN.parent}:' + os.environ.get('PATH', '')

    subprocess.run(['pip', 'install', '-q', 'gdown'], check=True)
    print("✅ SETUP завершён")


def _resolve_drive_folder(folder: str, parent_id: Optional[str]) -> str:
    if folder.startswith('http'):
        return folder
    if len(folder) >= 20 and '/' not in folder:
        return folder
    if not parent_id:
        raise RuntimeError("drive_parent_id не задан")

    url = f"https://drive.google.com/drive/folders/{parent_id}"
    print(f"🔍 Ищу подпапку '{folder}' в родительской папке...")

    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=25) as r:
            html = r.read().decode('utf-8', errors='replace')
    except Exception as e:
        raise RuntimeError(f"Не удалось загрузить страницу Drive: {e}")

    items = {}
    for m in re.finditer(r'data-id="([0-9A-Za-z_-]{20,})"', html):
        item_id = m.group(1)
        start = max(0, m.start() - 450)
        end = min(len(html), m.end() + 450)
        block = html[start:end]
        name_match = re.search(r'aria-label="([^"]+)"', block) or re.search(r'data-tooltip="([^"]+)"', block)
        if name_match:
            raw = name_match.group(1).split(',')[0].strip()
            for suf in [' Shared folder', ' Shared Folder', ' Folder', ' folder']:
                if raw.endswith(suf):
                    raw = raw[:-len(suf)].strip()
                    break
            items[raw] = item_id

    if folder in items:
        print(f"✅ Найдена подпапка '{folder}': {items[folder]}")
        return items[folder]

    for name, iid in items.items():
        if name.startswith(folder):
            print(f"✅ Найдена подпапка '{name}' → '{folder}': {iid}")
            return iid

    raise RuntimeError(f"Подпапка '{folder}' не найдена. Доступные: {list(items.keys())[:12]}")


def run(*, folder: str, langs: str = 'en', upload: str = 'api', **overrides):
    profile = {**DEFAULTS, **overrides}
    ensure_dirs()
    set_env(profile)

    for p in (SRC_DIR, VIDEO_DIR, SUBS_DIR, OUT_DIR, LOG_DIR):
        shutil.rmtree(p, ignore_errors=True)
        p.mkdir(parents=True, exist_ok=True)

    import gdown
    real_id = _resolve_drive_folder(folder, profile.get('drive_parent_id'))

    print(f"=== Скачивание подпапки {folder} ===")
    gdown.download_folder(id=real_id, output=str(SRC_DIR), quiet=False, use_cookies=False)

    for f in SRC_DIR.rglob('*'):
        if f.is_file():
            if f.suffix.lower() in {'.mp4', '.mkv'}:
                shutil.copy2(f, VIDEO_DIR / f.name)
            elif f.suffix.lower() == '.srt':
                shutil.copy2(f, SUBS_DIR / f.name)

    script = Path('/content/auto_translate_hardsub_colab.py')

    print("=== Запуск хардсаба ===")
    result = subprocess.run([
        'python', str(script), '--once',
        '--video-dir', str(VIDEO_DIR),
        '--subtitle-dir', str(SUBS_DIR),
        '--logo-dir', profile['logo_dir'],
        '--output-dir', str(OUT_DIR),
        '--log-dir', str(LOG_DIR),
        '--dest-langs', langs,
        '--encoder', profile['encoder'],
        '--skip-translation',
    ], capture_output=True, text=True)

    print(result.stdout)
    if result.stderr:
        print("STDERR:\n", result.stderr)

    if result.returncode != 0:
        raise RuntimeError(f"Хардсаб завершился с ошибкой: {result.returncode}")

    print(f"Готово файлов: {len(list(OUT_DIR.glob('*.mp4')))}")


def stop():
    import os
    os._exit(0)
