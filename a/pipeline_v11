# Кастомный чистый прогресс-бар для Colab, убирающий спам миллионом строк
import tqdm
class ColabProgressFormatter:
    def __init__(self, iterable=None, total=None, desc=None, initial=0, **kwargs):
        self.iterable = iterable
        self.total = total or (len(iterable) if iterable else None)
        self.n = initial
        self.last_pct = -1
        self.last_time = 0
    def __enter__(self): return self
    def __exit__(self, *a): pass
    def __iter__(self):
        if self.iterable:
            for obj in self.iterable:
                yield obj
                self.update(1)
    def update(self, n=1):
        self.n += n
        if self.total and self.total > 0:
            pct = int(self.n * 100 / self.total)
            now = time.time()
            if (pct >= self.last_pct + 10 or now - self.last_time > 8) and pct != self.last_pct:
                if pct <= 100:
                    print(f"📥 Загрузка из Drive: {pct}% ({self.n // (1024*1024)} MB из {self.total // (1024*1024)} MB)", flush=True)
                    self.last_pct = pct
                    self.last_time = now
    def close(self): pass
    def refresh(self): pass
    def set_description(self, *a, **k): pass

tqdm.tqdm = ColabProgressFormatter

def _ensure_dirs():
