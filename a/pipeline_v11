def _sftp_upload(files: Sequence[Path], host, user, port, path, password):
    env = os.environ.copy()
    env.update(SFTP_HOST=host, SFTP_USER=user, SFTP_PORT=port,
               SFTP_PATH=path, SFTP_PASS=password)
    src_list = ' '.join(f'"{f}"' for f in files)
    cmd = f'''
lftp -u "$SFTP_USER,$SFTP_PASS" -p "$SFTP_PORT" "sftp://$SFTP_HOST" <<EOF
set sftp:auto-confirm yes
set net:max-retries 3
set net:reconnect-interval-base 5
set xfer:clobber on
mkdir -p $SFTP_PATH
cd $SFTP_PATH
mput -P 2 {src_list}
bye
EOF
'''
    rc = subprocess.call(['bash', '-c', cmd], env=env)
    return (len(files), []) if rc == 0 else (0, list(files))


def _api_upload(fpath: Path, server, hostings, token,
                speed_limit_mbps=2, speed_time_sec=120, max_retries=3):
    size_mb = fpath.stat().st_size / 1024 / 1024
    speed_limit_bps = int(speed_limit_mbps * 1024 * 1024 / 8) if speed_limit_mbps > 0 else 0
    last = ''
    for attempt in range(1, max_retries + 1):
        t0 = time.time()
        args = ['curl', '-sS', '--fail-with-body', '-X', 'POST',
                '--connect-timeout', '30',
                '-H', f'X-API-Key: {token}',
                '-F', f'files=@{fpath}']
        if speed_limit_bps > 0:
            args += ['--speed-limit', str(speed_limit_bps),
                     '--speed-time', str(speed_time_sec)]
        for h in hostings:
            args += ['-F', f'hostings={h}']
        args += [f'{server}/api/upload']
        try:
            r = subprocess.run(args, capture_output=True, text=True, timeout=7200)
        except subprocess.TimeoutExpired:
            print(f'  [{attempt}/{max_retries}] hard timeout >2h')
            last = 'hard timeout'
            continue
        dt = time.time() - t0
        speed = (size_mb * 8) / dt if dt > 0 else 0

        if r.returncode == 0:
            resp = (r.stdout or '').strip()
            print(f'  OK in {dt:.1f}s  ({speed:.1f} Mbps)  attempt {attempt}')
            if resp:
                print('  Response:', resp[:400] + ('...' if len(resp) > 400 else ''))
            return True, f'{speed:.1f} Mbps, {dt:.0f}s'

        if r.returncode == 28:
            resp = (r.stdout or r.stderr or '').strip()
            if resp:
                rl = resp.lower()
                if any(s in rl for s in ('"status":"ok"', '"success":true', 'uploaded', 'task_id', 'job_id')):
                    print(f'  OK in {dt:.1f}s  ({speed:.1f} Mbps)  attempt {attempt} (curl28 but server replied OK)')
                    print('  Response:', resp[:400] + ('...' if len(resp) > 400 else ''))
                    return True, f'{speed:.1f} Mbps, {dt:.0f}s (curl28 ok)'
            if speed >= speed_limit_mbps:
                print(f'  [{attempt}/{max_retries}] connection dropped at {speed:.1f} Mbps avg — retry')
            else:
                print(f'  [{attempt}/{max_retries}] SLOW (<{speed_limit_mbps}Mbps {speed_time_sec}s), got {speed:.1f} Mbps — retry')
            last = f'slow/dropped ({speed:.1f} Mbps)'
            time.sleep(5)
            continue

        print(f'  [{attempt}/{max_retries}] FAIL exit={r.returncode}  ({dt:.1f}s)')
        print('  stderr:', (r.stderr or '')[-300:])
        print('  stdout:', (r.stdout or '')[-300:])
        last = f'curl exit {r.returncode}'
        if r.returncode in (6, 7, 18, 35, 52, 55, 56, 92):
            time.sleep(10)
            continue
        break
    return False, last


def list_outputs(langs: Union[str, Iterable[str], None] = None) -> List[Path]:
    files = sorted(p for p in OUT_DIR.glob('*.mp4') if p.is_file())
    if not langs:
        return files
    langs_set = {x.strip().lower() for x in (langs.split(',') if isinstance(langs, str) else langs)}
    out = []
    for f in files:
        stem = f.stem
        if '.' in stem:
            _, lang = stem.rsplit('.', 1)
            if lang.lower() in langs_set:
                out.append(f)
    return out


def _upload(files: Sequence[Path], targets: Sequence[str], **kw):
    res = {'sftp_ok': 0, 'sftp_fail': [], 'api_ok': 0, 'api_fail': []}
    if not files:
        print('[upload] нет файлов')
        return res
    if not targets:
        print('[upload] targets пуст, пропускаем')
        return res

    sec = _secrets()
    p = {**DEFAULTS, **kw}

    if 'sftp' in targets:
        pw = sec.get_secret('SFTP_PASS')
        print(f'\n--- SFTP -> {p["sftp_user"]}@{p["sftp_host"]}:{p["sftp_path"]} ({len(files)} файлов) ---')
        ok, fail = _sftp_upload(files, p['sftp_host'], p['sftp_user'],
                                p['sftp_port'], p['sftp_path'], pw)
        res['sftp_ok'] = ok
        res['sftp_fail'] = [f.name for f in fail]
        print(f'SFTP: OK {ok}, FAIL {len(fail)}')

    if 'api' in targets:
        token = sec.get_secret('UPLOAD_API_TOKEN')
        print(f'\n--- API -> {p["api_server"]}/api/upload  hostings={p["api_hostings"]} ---')
        for i, f in enumerate(files, 1):
            mb = f.stat().st_size / 1024 / 1024
            print(f'\n  [{i}/{len(files)}] {f.name}  ({mb:.1f} MB)')
            ok, info = _api_upload(
                f, p['api_server'], p['api_hostings'], token,
                speed_limit_mbps=p['api_speed_limit_mbps'],
                speed_time_sec=p['api_speed_time_sec'],
                max_retries=p['api_max_retries'],
            )
            if ok:
                res['api_ok'] += 1
            else:
                res['api_fail'].append((f.name, info))

    if 'dm' in targets:
        print(f'\n--- DM -> Dailymotion ({len(files)} файлов) ---')
        dm_res = upload_dm(files=[f.name for f in files])
        res['dm_ok'] = dm_res.get('dm_ok', 0)
        res['dm_fail'] = dm_res.get('dm_fail', [])

    return res


