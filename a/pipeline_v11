        p.mkdir(parents=True, exist_ok=True)

def _ensure_script(logo_dir: str) -> Path:
    dst = WORKING / SCRIPT_NAME
    src = Path(logo_dir) / SCRIPT_NAME
    if not dst.exists():
        if not src.exists():
            raise RuntimeError(
                f'{SCRIPT_NAME} не найден ни в {dst}, ни в {src}.\n'
                f'Положите его в один из этих путей.'
            )
        shutil.copy2(src, dst)
        print(f'Script copied: {src} -> {dst}')
    return dst

def _set_env(profile: dict):
    os.environ['PATH'] = f'{FFMPEG_BIN.parent}:' + os.environ.get('PATH', '')
    os.environ['FFMPEG_PATH']     = str(FFMPEG_BIN)
    os.environ['FFPROBE_PATH']    = str(FFPROBE_BIN)

    threads = profile.get('ffmpeg_threads', 'auto')
    parallel = int(profile.get('render_parallel', 1))
    if threads == 'auto' or threads is None:
        try:
            cpu_total = os.cpu_count() or 2
        except Exception:
            cpu_total = 2
        threads = max(1, cpu_total // max(1, parallel))
    os.environ['FFMPEG_THREADS']  = str(threads)
    os.environ['RENDER_PARALLEL'] = str(parallel)
    print(f'⚙️  CPU: {os.cpu_count()} ядер | RENDER_PARALLEL={parallel} | FFMPEG_THREADS={threads}')

    if profile.get('gpu_overlay'):
        os.environ['USE_GPU_OVERLAY'] = '1'
    else:
        os.environ['USE_GPU_OVERLAY'] = '0'

    ldir = profile['logo_dir']
    os.environ['LOGO_EN'] = profile['logo_en'] or f'{ldir}/logo riki.png'
    os.environ['LOGO_IT'] = profile['logo_it'] or f'{ldir}/logo.png'
    os.environ['LOGO_ES'] = profile['logo_es'] or f'{ldir}/logo.png'

