def write_log(text: str) -> None:
    Ctx.log_path.parent.mkdir(parents=True, exist_ok=True)
    line = f"{time.strftime('%Y-%m-%d %H:%M:%S')}  {text}"
    with Ctx.log_path.open("a", encoding="utf-8") as f:
        f.write(line + "\n")
    print(line, flush=True)

def update_heartbeat() -> None:
    Ctx.heartbeat_path.parent.mkdir(parents=True, exist_ok=True)
    Ctx.heartbeat_path.write_text(time.strftime("%Y-%m-%d %H:%M:%S"), encoding="utf-8")

def ensure_commands_exist() -> None:
    if shutil.which(FFMPEG_PATH) is None: raise RuntimeError("FFmpeg not found")
    if shutil.which(FFPROBE_PATH) is None: raise RuntimeError("FFprobe not found")

def detect_encoder(preferred: str) -> str:
    if preferred == "libx264": return "libx264"
    try:
        proc = subprocess.run([FFMPEG_PATH, "-hide_banner", "-encoders"], capture_output=True, text=True)
        has_nvenc = "h264_nvenc" in (proc.stdout or "")
    except:
        has_nvenc = False
    return "nvenc" if has_nvenc else "libx264"

def get_media_size(path: Path) -> Tuple[int, int]:
    proc = subprocess.run([FFPROBE_PATH, "-v", "error", "-select_streams", "v:0",
                           "-show_entries", "stream=width,height", "-of", "csv=s=x:p=0", str(path)],
                          capture_output=True, text=True)
    w, h = proc.stdout.strip().split("x")
    return int(w), int(h)

def get_video_codec(path: Path) -> str:
    try:
        proc = subprocess.run([FFPROBE_PATH, "-v", "error", "-select_streams", "v:0",
                               "-show_entries", "stream=codec_name", "-of", "csv=p=0", str(path)],
                              capture_output=True, text=True)
        return proc.stdout.strip().lower()
    except:
        return ""

def new_temp_subtitle_copy(original_path: Path) -> Path:
    temp_dir = Path(tempfile.gettempdir()) / "AutoHardSubTempSubs"
    temp_dir.mkdir(parents=True, exist_ok=True)
    temp_path = temp_dir / f"sub_{next(tempfile._get_candidate_names())}.srt"
    shutil.copy2(original_path, temp_path)
    return temp_path

def escape_subtitle_path_for_filter(path: Path) -> str:
    return str(path.resolve()).replace("\\", "/").replace(":", r"\:").replace("'", r"\'")

def get_subtitle_style(video_height: int) -> str:
    font_size = max(18, round(video_height * SUB_FONT_PCT_OF_HEIGHT))
    outline = round(video_height * SUB_OUTLINE_PCT_OF_HEIGHT, 2)
    margin_v = max(18, int(round(video_height * SUB_MARGIN_V_PCT_OF_HEIGHT)))
    return (f"Fontname=DejaVu Sans,Fontsize={font_size},Bold=1,BorderStyle=1,"
            f"Outline={outline},Shadow=0,PrimaryColour={SUB_PRIMARY_COLOR},"
            f"OutlineColour={SUB_OUTLINE_COLOR},Alignment=2,MarginV={margin_v}")

def get_overlay_position(video_w, video_h, logo_w, logo_h, profile):
    mx = int(round(video_w * float(profile["MarginXPct"])))
    my = int(round(video_h * float(profile["MarginYPct"])))
    anchor = str(profile["Anchor"]).lower()
    if anchor == "bottomleft": return mx, video_h - logo_h - my
    if anchor == "topleft": return mx, my
    if anchor == "bottomright": return video_w - logo_w - mx, video_h - logo_h - my
    return video_w - logo_w - mx, my

def download_logos():
    os.makedirs(str(DEFAULT_LOGO_DIR), exist_ok=True)
    urls = {
        str(DEFAULT_LOGO_DIR / "logo riki.png"): "https://raw.githubusercontent.com/Iwaki9/iwaki/refs/heads/master/a/logo%20riki.png",
        str(DEFAULT_LOGO_DIR / "logo.png"): "https://raw.githubusercontent.com/Iwaki9/iwaki/refs/heads/master/a/logo.png"
    }
    for path, url in urls.items():
        if not os.path.exists(path):
            subprocess.run(["wget", "-q", "-O", path, url], check=True)

def split_subtitle_stem_and_lang(path: Path):
    stem = path.stem
    match = re.match(r"^(?P<base>.+)\.(?P<lang>[A-Za-z]{2,5})$", stem)
    if not match: return stem, None
    lang = match.group("lang").lower()
    base = match.group("base")
    known = set(KNOWN_LANGUAGE_SUFFIXES) | {Ctx.src_lang.lower()} | {x.lower() for x in Ctx.dest_langs}
    return (base, lang) if lang in known else (stem, None)

def is_raw_subtitle_source(path: Path) -> bool:
    return path.suffix.lower() == ".srt" and split_subtitle_stem_and_lang(path)[1] is None

def build_translated_subtitle_path(raw, dest_lang):
    return raw.with_name(f"{raw.stem}.{dest_lang}{raw.suffix}")

_NLLB_PIPE = None

def _get_nllb_pipeline():
    global _NLLB_PIPE
    if _NLLB_PIPE: return _NLLB_PIPE
    import torch
    from transformers import AutoModelForSeq2SeqLM, AutoTokenizer
    device = 0 if torch.cuda.is_available() else -1
    tokenizer = AutoTokenizer.from_pretrained(DEFAULT_NLLB_MODEL)
    model = AutoModelForSeq2SeqLM.from_pretrained(DEFAULT_NLLB_MODEL, torch_dtype=torch.float16 if device == 0 else torch.float32)
    if device == 0: model = model.to("cuda")
    _NLLB_PIPE = {"tokenizer": tokenizer, "model": model, "device": device}
    return _NLLB_PIPE

def _nllb_code(lang): return NLLB_LANG_MAP[lang.lower()]

def translate_batch_local(texts, src, dest):
    if not texts: return []
    pipe = _get_nllb_pipeline()
    tokenizer, model, device = pipe["tokenizer"], pipe["model"], pipe["device"]
    tokenizer.src_lang = _nllb_code(src)
    import torch
    results = []
    for i in range(0, len(texts), TRANSLATE_BATCH_SIZE):
        chunk = texts[i:i+TRANSLATE_BATCH_SIZE]
        inputs = tokenizer(chunk, return_tensors="pt", padding=True, truncation=True, max_length=TRANSLATE_MAX_LENGTH)
        if device == 0: inputs = {k: v.to("cuda") for k, v in inputs.items()}
        forced_bos = tokenizer.convert_tokens_to_ids(_nllb_code(dest))
        with torch.no_grad():
            out = model.generate(**inputs, forced_bos_token_id=forced_bos, max_length=TRANSLATE_MAX_LENGTH, num_beams=2)
        results.extend(tokenizer.batch_decode(out, skip_special_tokens=True))
    return results

def get_state_dir(p): return (p / STATE_DIR_NAME).mkdir(parents=True, exist_ok=True) or (p / STATE_DIR_NAME)
def get_sidecar_path(f, s): return get_state_dir(f.parent) / f"{f.name}{s}"
def get_meta_path(f): return get_sidecar_path(f, ".meta.json")
def load_meta(f):
    if not get_meta_path(f).exists(): return None
    try: return json.loads(get_meta_path(f).read_text())
    except: return None
def save_meta(f, m): get_meta_path(f).write_text(json.dumps(m, ensure_ascii=False, indent=2))

def translate_subtitle_file(i, o, src, dst):
    subs = pysrt.open(str(i), encoding="utf-8")
    total = len(subs)
    meta = load_meta(o) or {"last_done_index": -1}
    start = meta.get("last_done_index", -1) + 1
    for j in range(start, total, TRANSLATE_BATCH_SIZE):
        batch = [subs[k].text for k in range(j, min(j+TRANSLATE_BATCH_SIZE, total)) if subs[k].text.strip()]
        if not batch: continue
        translated = translate_batch_local(batch, src, dst)
        for idx, t in enumerate(translated):
            subs[j + idx].text = t.strip()
        meta["last_done_index"] = j + len(translated) - 1
        save_meta(o, meta)
    write_log(f"TRANS DONE {o}")

def process_raw_subtitle(raw):
    if not is_raw_subtitle_source(raw): return 0
    for lang in Ctx.dest_langs:
        out = build_translated_subtitle_path(raw, lang)
        if not os.path.exists(str(out)):
            translate_subtitle_file(raw, out, Ctx.src_lang, lang)
    return 1

def iter_video_files():
    return [p for p in Ctx.video_dir.iterdir() if p.is_file() and p.suffix.lower() in VIDEO_EXTENSIONS] if Ctx.video_dir.exists() else []

def iter_subtitle_files():
    return [p for p in Ctx.subtitle_dir.iterdir() if p.is_file() and p.suffix.lower() == ".srt"] if Ctx.subtitle_dir.exists() else []

def workflow2_common_base(name):
    s = name
    if s.lower().endswith((".srt", ".mp4")): s = s.rsplit(".", 1)[0]
    m = re.match(r"^(?P<base>.+)\.(?P<lang>[A-Za-z]{2,5})$", s)
    if m and m.group("lang").lower() in set(KNOWN_LANGUAGE_SUFFIXES) | {Ctx.src_lang.lower()} | {x.lower() for x in Ctx.dest_langs}:
        s = m.group("base")
    for suf in ("_audio_original", "_audio", "_video"):
        if s.endswith(suf): s = s[:-len(suf)]; break
    return s

def resolve_logo_path(lang):
    env = os.environ.get(f"LOGO_{lang.upper()}")
    if env and Path(env).exists(): return Path(env)
    for ext in (".png", ".jpg", ".jpeg"):
        p = Ctx.logo_dir / f"{lang}{ext}"
        if p.exists(): return p
    return None

def render_one(video, subtitle, lang, output_base=None):
    profile = LANGUAGE_PROFILES.get(lang)
    if not profile: return False
    logo = resolve_logo_path(lang)
    base = output_base or video.stem
    out = Ctx.output_dir / f"{base}.{lang}.mp4"
    if out.exists(): return False

    w, h = get_media_size(video)
    style = get_subtitle_style(h)
    temp = new_temp_subtitle_copy(subtitle)
    esc = escape_subtitle_path_for_filter(temp)

    decode = []
    if Ctx.encoder == "nvenc" and os.environ.get("DISABLE_HWACCEL", "0") != "1":
        codec = get_video_codec(video)
        if codec in {"h264", "hevc", "h265", "vp8", "vp9", "mpeg2video", "mpeg4", "vc1"}:
            decode = ["-hwaccel", "cuda"]

    if logo:
        lw, lh = get_media_size(logo)
        lw2 = max(2, int(w * profile["LogoWidthPct"]))
        lh2 = max(2, int((lh / lw) * lw2))
        x, y = get_overlay_position(w, h, lw2, lh2, profile)
        fc = f"[1:v]format=rgba,colorchannelmixer=aa={profile['Alpha']},scale={lw2}:{lh2}[wm];[0:v]subtitles='{esc}':force_style='{style}'[v0];[v0][wm]overlay={x}:{y}[v]"
        ins = [*decode, "-i", str(video), "-i", str(logo)]
    else:
        fc = f"[0:v]subtitles='{esc}':force_style='{style}'[v]"
        ins = [*decode, "-i", str(video)]

    venc = ["-c:v", "h264_nvenc", "-preset", NVENC_PRESET, "-b:v", VIDEO_BITRATE, "-maxrate", MAXRATE, "-bufsize", BUFSIZE] if Ctx.encoder == "nvenc" else ["-c:v", "libx264", "-preset", "veryfast", "-b:v", VIDEO_BITRATE, "-maxrate", MAXRATE, "-bufsize", BUFSIZE, "-pix_fmt", "yuv420p"]

    args = [FFMPEG_PATH, "-y", "-hide_banner", "-loglevel", "error", *ins, "-filter_complex", fc, "-map", "[v]", "-map", "0:a?", *venc]
    if USE_AUDIO_COPY: args += ["-c:a", "copy"]
    else: args += ["-c:a", "aac", "-b:a", "128k"]
    args.append(str(out))

    try:
        proc = subprocess.run(args, capture_output=True, text=True)
        return proc.returncode == 0 and out.exists()
    finally:
        temp.unlink(missing_ok=True)

def process_render_jobs():
    tasks = []
    for v in iter_video_files():
        base = workflow2_common_base(v.stem) if Ctx.naming == "workflow2" else v.stem
        for lang in Ctx.dest_langs:
            cands = [s for s in iter_subtitle_files() if s.name.lower().endswith(f".{lang}.srt") and workflow2_common_base(s.stem).lower() == base.lower()] if Ctx.naming == "workflow2" else ([Ctx.subtitle_dir / f"{base}.{lang}.srt"] if (Ctx.subtitle_dir / f"{base}.{lang}.srt").exists() else [])
            if cands: tasks.append((v, cands[0], lang, base))
    if not tasks: return 0
    return sum(render_one(v, s, l, output_base=b) for v, s, l, b in tasks)

def process_translation_jobs():
    return sum(process_raw_subtitle(s) for s in iter_subtitle_files() if is_raw_subtitle_source(s))

def validate_paths():
    for p in [Ctx.video_dir, Ctx.subtitle_dir, Ctx.logo_dir, Ctx.output_dir, Ctx.log_dir]:
        p.mkdir(parents=True, exist_ok=True)

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--once", action="store_true")
    parser.add_argument("--video-dir", default=str(DEFAULT_VIDEO_DIR))
    parser.add_argument("--subtitle-dir", default=str(DEFAULT_SUBTITLE_DIR))
    parser.add_argument("--logo-dir", default=str(DEFAULT_LOGO_DIR))
    parser.add_argument("--output-dir", default=str(DEFAULT_OUTPUT_DIR))
    parser.add_argument("--log-dir", default=str(DEFAULT_LOG_DIR))
    parser.add_argument("--src-lang", default="tr")
    parser.add_argument("--dest-langs", default="en,it,es")
    parser.add_argument("--encoder", default="auto")
    parser.add_argument("--skip-translation", action="store_true")
    parser.add_argument("--skip-render", action="store_true")
    parser.add_argument("--naming", default="stem")
    args = parser.parse_args()

    Ctx.video_dir = Path(args.video_dir)
    Ctx.subtitle_dir = Path(args.subtitle_dir)
    Ctx.logo_dir = Path(args.logo_dir)
    Ctx.output_dir = Path(args.output_dir)
    Ctx.log_dir = Path(args.log_dir)
    Ctx.log_path = Ctx.log_dir / "AutoTranslateHardSub.log"
    Ctx.heartbeat_path = Ctx.log_dir / "AutoTranslateHardSub.heartbeat.txt"
    Ctx.src_lang = args.src_lang.lower()
    Ctx.dest_langs = [x.strip().lower() for x in args.dest_langs.split(",") if x.strip()]
    Ctx.skip_translation = args.skip_translation
    Ctx.naming = args.naming

    download_logos()
    ensure_commands_exist()
    validate_paths()
    Ctx.encoder = detect_encoder(args.encoder)

    write_log("=== Colab HardSub started ===")
    if not Ctx.skip_translation: process_translation_jobs()
    if not args.skip_render: process_render_jobs()
    write_log("=== Colab HardSub finished ===")

if __name__ == "__main__":
    main()
