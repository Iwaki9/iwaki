def split_subtitle_stem_and_lang(path: Path):
    stem = path.stem
    match = re.match(r"^(?P<base>.+)\.(?P<lang>[A-Za-z]{2,5})$", stem)
    if not match: return stem, None
    lang = match.group("lang").lower()
    base = match.group("base")
    known = set(KNOWN_LANGUAGE_SUFFIXES) | {Ctx.src_lang.lower()} | {x.lower() for x in Ctx.dest_langs}
    return (base, lang) if lang in known else (stem, None)

def is_raw_subtitle_source(path: Path) -> bool:
    return path.suffix.lower() == ".srt" and split_subtitle_stem_and_lang(path)[1] is None

def build_translated_subtitle_path(raw, dest_lang):
    return raw.with_name(f"{raw.stem}.{dest_lang}{raw.suffix}")

