# GPU-монитор (синглтон, общий на все параллельные воркеры)
# =========================================================
import threading as _threading_mon
_GPU_MON_LOCK = _threading_mon.Lock()
_GPU_MON_REFCOUNT = 0
_GPU_MON_STOP: Optional[_threading_mon.Event] = None
_GPU_MON_THREAD: Optional[_threading_mon.Thread] = None


def _gpu_monitor_loop(stop_event, interval: float) -> None:
    while not stop_event.wait(interval):
        try:
            r = subprocess.run(
                ["nvidia-smi",
                 "--query-gpu=index,utilization.gpu,utilization.encoder,utilization.decoder,memory.used",
                 "--format=csv,noheader,nounits"],
                capture_output=True, text=True, timeout=5,
            )
            if r.returncode != 0:
                continue
            parts = []
            for line in r.stdout.strip().splitlines():
                cols = [x.strip() for x in line.split(",")]
                if len(cols) >= 5:
                    idx, gpu, enc, dec, mem = cols[:5]
                    parts.append(f"GPU{idx}: util={gpu}% NVENC={enc}% NVDEC={dec}% vram={mem}MB")
            if parts:
                write_log("  ".join(parts))
        except Exception as _e:
            write_log(f"GPU monitor warn: {_e}")


def gpu_monitor_acquire() -> None:
    global _GPU_MON_REFCOUNT, _GPU_MON_STOP, _GPU_MON_THREAD
    interval = float(os.environ.get("GPU_MONITOR_INTERVAL", "15"))
    if interval <= 0 or not shutil.which("nvidia-smi"):
        return
    with _GPU_MON_LOCK:
        if _GPU_MON_REFCOUNT == 0:
            _GPU_MON_STOP = _threading_mon.Event()
            _GPU_MON_THREAD = _threading_mon.Thread(
                target=_gpu_monitor_loop, args=(_GPU_MON_STOP, interval),
                name="gpu-monitor", daemon=True,
            )
            _GPU_MON_THREAD.start()
        _GPU_MON_REFCOUNT += 1


def gpu_monitor_release() -> None:
    global _GPU_MON_REFCOUNT, _GPU_MON_STOP, _GPU_MON_THREAD
    with _GPU_MON_LOCK:
        _GPU_MON_REFCOUNT = max(0, _GPU_MON_REFCOUNT - 1)
        if _GPU_MON_REFCOUNT == 0 and _GPU_MON_STOP is not None:
            _GPU_MON_STOP.set()
            if _GPU_MON_THREAD is not None:
                _GPU_MON_THREAD.join(timeout=2)
            _GPU_MON_STOP = None
            _GPU_MON_THREAD = None


def write_log(text: str) -> None:
    Ctx.log_path.parent.mkdir(parents=True, exist_ok=True)
    line = f"{time.strftime('%Y-%m-%d %H:%M:%S')}  {text}"
    with Ctx.log_path.open("a", encoding="utf-8") as f:
        f.write(line + "\n")
    print(line, flush=True)


