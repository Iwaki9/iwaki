def iter_video_files() -> List[Path]:
    if not Ctx.video_dir.exists():
        return []
    return [p for p in Ctx.video_dir.iterdir()
            if p.is_file() and p.suffix.lower() in VIDEO_EXTENSIONS]


def iter_subtitle_files() -> List[Path]:
    if not Ctx.subtitle_dir.exists():
        return []
    return [p for p in Ctx.subtitle_dir.iterdir()
            if p.is_file() and p.suffix.lower() == ".srt"]


def find_video_for_base(base: str) -> Optional[Path]:
    for video in iter_video_files():
        if video.stem.lower() == base.lower():
            return video
    return None


def workflow2_common_base(name: str) -> str:
    """
    Для схемы 'workflow2': возвращает общий префикс файла без суффиксов
    '_video', '_audio', '_audio_original' и языкового хвоста.
    Примеры:
      'Foo_video'              -> 'Foo'
      'Foo_audio'              -> 'Foo'
      'Foo_audio.en'           -> 'Foo'  (без .srt)
      'Foo_audio_original'     -> 'Foo'
    """
    s = name
    # отрезаем расширение если ещё осталось
    if s.lower().endswith(".srt") or s.lower().endswith(".mp4"):
        s = s.rsplit(".", 1)[0]
    # языковой хвост
    m = re.match(r"^(?P<base>.+)\.(?P<lang>[A-Za-z]{2,5})$", s)
    if m:
        known = set(KNOWN_LANGUAGE_SUFFIXES)
        known.update({Ctx.src_lang.lower(), *[x.lower() for x in Ctx.dest_langs]})
        if m.group("lang").lower() in known:
            s = m.group("base")
    # суффиксы рабочего пайплайна
    for suf in ("_audio_original", "_audio", "_video"):
        if s.endswith(suf):
            s = s[: -len(suf)]
            break
    return s


def find_video_workflow2(common_base: str) -> Optional[Path]:
    """Ищем <common_base>_video.<ext> среди видео."""
    cb_lower = common_base.lower()
    for video in iter_video_files():
        if workflow2_common_base(video.stem).lower() == cb_lower:
            return video
    return None


def resolve_logo_path(lang: str) -> Optional[Path]:
    """Ищем <logo_dir>/<lang>.{png,jpg,jpeg,webp} либо берём из переменной окружения LOGO_<LANG>."""
    env_override = os.environ.get(f"LOGO_{lang.upper()}")
    if env_override:
        p = Path(env_override)
        if p.exists():
            return p
    for ext in (".png", ".jpg", ".jpeg", ".webp"):
        candidate = Ctx.logo_dir / f"{lang}{ext}"
        if candidate.exists():
            return candidate
    return None


def render_one(video: Path, subtitle: Path, lang: str,
               output_base: Optional[str] = None,
               gpu_index: Optional[int] = None) -> bool:
    profile = LANGUAGE_PROFILES.get(lang)
    if profile is None:
        write_log(f"RENDER SKIP no profile for lang={lang}")
        return False

    logo = resolve_logo_path(lang)
    base_name = output_base if output_base else video.stem
    output_path = Ctx.output_dir / f"{base_name}.{lang}.mp4"
    done_path = get_sidecar_path(output_path, ".done")
    failed_path = get_sidecar_path(output_path, ".failed")
    lock_path = get_sidecar_path(output_path, ".rendering")

    if done_path.exists() or output_path.exists():
        write_log(f"RENDER SKIP already exists {output_path.name}")
        return False

    video_w, video_h = get_media_size(video)
    style = get_subtitle_style(video_h)
    temp_sub = new_temp_subtitle_copy(subtitle)
    escaped_sub = escape_subtitle_path_for_filter(temp_sub)

    # GPU-декодирование исходного видео (если NVENC выбран)
    # Tesla T4 не умеет AV1 hwdec, поэтому проверяем кодек.
    # Поддерживаемые T4 NVDEC: h264, hevc, vp8, vp9, mpeg2, mpeg4, vc1.
    decode_args: List[str] = []
    if Ctx.encoder == "nvenc" and os.environ.get("DISABLE_HWACCEL", "0") != "1":
        codec = get_video_codec(video)
        hwdec_supported = {"h264", "hevc", "h265", "vp8", "vp9", "mpeg2video", "mpeg4", "vc1"}
        if codec in hwdec_supported:
            decode_args = ["-hwaccel", "cuda"]
            write_log(f"RENDER hwdec=cuda (codec={codec})")
        else:
            write_log(f"RENDER hwdec=off (codec={codec} not supported by T4 NVDEC, using CPU decode)")

    if logo is not None:
        try:
            logo_w0, logo_h0 = get_media_size(logo)
            logo_w = get_even_int(video_w * float(profile["LogoWidthPct"]))
            logo_h = get_even_int((logo_h0 / logo_w0) * logo_w)
            pos_x, pos_y = get_overlay_position(video_w, video_h, logo_w, logo_h, profile)
            use_gpu_overlay = (
                Ctx.encoder == "nvenc"
                and os.environ.get("USE_GPU_OVERLAY", "0") == "1"
            )
            if use_gpu_overlay:
                # GPU pipeline: после libass отправляем кадр на GPU и оверлей+энкод там же.
                # Логотип готовится на CPU (alpha + scale), потом hwupload_cuda.
                # Это снимает нагрузку с CPU на overlay и убирает финальный upload перед NVENC.
                filter_complex = (
                    f"[1:v]format=rgba,colorchannelmixer=aa={profile['Alpha']},"
                    f"scale={logo_w}:{logo_h},format=yuva420p,hwupload_cuda[wm];"
                    f"[0:v]subtitles='{escaped_sub}':force_style='{style}',"
                    f"format=yuv420p,hwupload_cuda[v0];"
                    f"[v0][wm]overlay_cuda=x={pos_x}:y={pos_y}[v]"
                )
                write_log("RENDER overlay=GPU (overlay_cuda)")
            else:
                filter_complex = (
                    f"[1:v]format=rgba,colorchannelmixer=aa={profile['Alpha']},"
                    f"scale={logo_w}:{logo_h}[wm];"
                    f"[0:v]subtitles='{escaped_sub}':force_style='{style}'[v0];"
                    f"[v0][wm]overlay={pos_x}:{pos_y}[v]"
                )
            inputs = [*decode_args, "-i", str(video), "-i", str(logo)]
        except Exception as e:
            write_log(f"RENDER WARN logo unusable ({logo}): {e}; rendering without logo")
            logo = None

    if logo is None:
        filter_complex = f"[0:v]subtitles='{escaped_sub}':force_style='{style}'[v]"
        inputs = [*decode_args, "-i", str(video)]

    lock_path.write_text("rendering", encoding="utf-8")
    # окружение для ffmpeg: можно закрепить за конкретным GPU
    ffmpeg_env = os.environ.copy()
    if gpu_index is not None:
        ffmpeg_env["CUDA_VISIBLE_DEVICES"] = str(gpu_index)
    gpu_tag = f" [gpu={gpu_index}]" if gpu_index is not None else ""
    try:
        write_log(f"RENDER START {video.name} [{lang}]{gpu_tag} -> {output_path.name}")

        # выбор кодировщика
        if Ctx.encoder == "nvenc":
            venc_args = [
                "-c:v", "h264_nvenc",
                "-preset", NVENC_PRESET,
                "-b:v", VIDEO_BITRATE,
                "-maxrate", MAXRATE,
                "-bufsize", BUFSIZE,
            ]
        else:
            venc_args = [
                "-c:v", "libx264",
                "-preset", "veryfast",
                "-b:v", VIDEO_BITRATE,
                "-maxrate", MAXRATE,
                "-bufsize", BUFSIZE,
                "-pix_fmt", "yuv420p",
            ]

        # Параллелизация фильтров (libass — однопоточный, но конвейер можно ускорить)
        threads_env = os.environ.get("FFMPEG_THREADS", "0")  # 0 = auto

        # Уровень логов ffmpeg: по умолчанию error+stats, можно переопределить env
        loglevel = os.environ.get("FFMPEG_LOGLEVEL", "error")
        # Прогресс по кадрам в stdout (компактно, одна строка)
        quiet_mode = os.environ.get("FFMPEG_QUIET", "1") != "0"

        args = [
            FFMPEG_PATH,
            "-y",
            "-hide_banner",
            "-loglevel", loglevel,
            "-stats",
            "-threads", threads_env,
            "-filter_threads", threads_env,
            "-filter_complex_threads", threads_env,
            *inputs,
            "-filter_complex", filter_complex,
            "-map", "[v]",
            "-map", "0:a?",
            *venc_args,
        ]
        if USE_AUDIO_COPY:
            args += ["-c:a", "copy"]
        else:
            args += ["-c:a", "aac", "-b:a", "128k"]
        args.append(str(output_path))

        if quiet_mode:
            # Подавляем шум: stderr собираем во временный файл и читаем только последние строки если ошибка
            import tempfile as _tf
            with _tf.NamedTemporaryFile(mode="w+", delete=False, suffix=".ffmpeg.log", encoding="utf-8") as _logf:
                _err_path = _logf.name

            # Регистрируемся у общего GPU-монитора (синглтон, один на весь скрипт)
            gpu_monitor_acquire()
            try:
                with open(_err_path, "w", encoding="utf-8") as _errf:
                    proc = subprocess.run(args, stdout=subprocess.DEVNULL, stderr=_errf, env=ffmpeg_env)
                exit_code = proc.returncode
            finally:
                gpu_monitor_release()

            if exit_code != 0:
                # При ошибке вытащим хвост лога
                try:
                    with open(_err_path, "r", encoding="utf-8", errors="replace") as _errf:
                        tail = _errf.readlines()[-40:]
                    write_log("FFmpeg stderr tail:\n" + "".join(tail))
                except Exception:
                    pass
            try:
                os.unlink(_err_path)
            except Exception:
                pass
        else:
            proc = subprocess.run(args, env=ffmpeg_env)
            exit_code = proc.returncode

        output_ok = output_path.exists() and output_path.stat().st_size > 1 * 1024 * 1024
        if exit_code == 0 or output_ok:
            done_path.write_text(f"Done at {time.strftime('%Y-%m-%d %H:%M:%S')}", encoding="utf-8")
            if failed_path.exists():
                failed_path.unlink(missing_ok=True)
            write_log(f"RENDER DONE {output_path}")
            return True
        else:
            if output_path.exists():
                output_path.unlink(missing_ok=True)
            failed_path.write_text(
                f"Failed at {time.strftime('%Y-%m-%d %H:%M:%S')}; exit={exit_code}",
                encoding="utf-8",
            )
            write_log(f"RENDER FAIL exit={exit_code} {video.name} [{lang}]")
            return False
    finally:
        lock_path.unlink(missing_ok=True)
        temp_sub.unlink(missing_ok=True)
        update_heartbeat()


def process_render_jobs() -> int:
    # Список задач: (video, subtitle, lang, common_base)
    tasks: List[Tuple[Path, Path, str, str]] = []
    for video in iter_video_files():
        if Ctx.naming == "workflow2":
            common_base = workflow2_common_base(video.stem)
        else:
            common_base = video.stem

        for lang in Ctx.dest_langs:
            candidates: List[Path] = []
            if Ctx.naming == "workflow2":
                for srt in iter_subtitle_files():
                    if not srt.name.lower().endswith(f".{lang}.srt"):
                        continue
                    if workflow2_common_base(srt.stem).lower() == common_base.lower():
                        candidates.append(srt)
            else:
                p = Ctx.subtitle_dir / f"{common_base}.{lang}.srt"
                if p.exists():
                    candidates.append(p)
            if not candidates:
                continue
            tasks.append((video, candidates[0], lang, common_base))

    if not tasks:
        return 0

    # Параллельный режим: если задач > 1 и есть несколько GPU
    parallel = max(1, int(os.environ.get("RENDER_PARALLEL", "1")))
    if parallel <= 1:
        started = 0
        for video, sub, lang, base in tasks:
            try:
                if render_one(video, sub, lang, output_base=base):
                    started += 1
            except Exception as e:
                write_log(f"RENDER ERROR {video.name} [{lang}] -> {e}")
        return started

    # Параллельно
    import threading as _th
    write_log(f"RENDER parallel mode: {parallel} workers")
    started_counter = [0]
    counter_lock = _th.Lock()
    task_lock = _th.Lock()
    task_iter = iter(enumerate(tasks))

    def worker(gpu_idx: int):
        while True:
            with task_lock:
                try:
                    task_no, (video, sub, lang, base) = next(task_iter)
                except StopIteration:
                    return
            try:
                if render_one(video, sub, lang, output_base=base, gpu_index=gpu_idx):
                    with counter_lock:
                        started_counter[0] += 1
            except Exception as e:
                write_log(f"RENDER ERROR {video.name} [{lang}] (gpu={gpu_idx}) -> {e}")

    threads = []
    for i in range(parallel):
        t = _th.Thread(target=worker, args=(i,), name=f"render-gpu{i}", daemon=True)
        t.start()
        threads.append(t)
    for t in threads:
        t.join()
    return started_counter[0]


def process_translation_jobs() -> int:
    started = 0
    for subtitle in iter_subtitle_files():
        if not is_raw_subtitle_source(subtitle):
            continue
        try:
            started += process_raw_subtitle(subtitle)
        except Exception as e:
            write_log(f"TRANS ERROR {subtitle.name} -> {e}")
    return started


