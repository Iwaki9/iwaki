    "tr": "tur_Latn", "en": "eng_Latn", "it": "ita_Latn", "es": "spa_Latn",
    "ru": "rus_Cyrl", "fr": "fra_Latn", "de": "deu_Latn", "pt": "por_Latn",
}

NVENC_PRESET = "p1"
VIDEO_BITRATE = "2000k"
MAXRATE = "2000k"
BUFSIZE = "4000k"
USE_AUDIO_COPY = True

SUB_FONT_PCT_OF_HEIGHT = 0.018
SUB_OUTLINE_PCT_OF_HEIGHT = 0.0005
SUB_MARGIN_V_PCT_OF_HEIGHT = 0.026
SUB_PRIMARY_COLOR = "&H00FFFFFF"
SUB_OUTLINE_COLOR = "&H00000000"

LANGUAGE_PROFILES: Dict[str, Dict[str, object]] = {
    "en": {"Anchor": "BottomLeft", "LogoWidthPct": 0.295, "MarginXPct": 0.018, "MarginYPct": 0.074, "Alpha": 0.10},
    "it": {"Anchor": "TopLeft", "LogoWidthPct": 0.295, "MarginXPct": 0.001, "MarginYPct": 0.001, "Alpha": 0.60},
