def split_subtitle_stem_and_lang(path: Path) -> Tuple[str, Optional[str]]:
    stem = path.stem
    match = re.match(r"^(?P<base>.+)\.(?P<lang>[A-Za-z]{2,5})$", stem)
    if not match:
        return stem, None
    lang = match.group("lang").lower()
    base = match.group("base")
    known = set(KNOWN_LANGUAGE_SUFFIXES)
    known.update({Ctx.src_lang.lower(), *[x.lower() for x in Ctx.dest_langs]})
    if lang in known:
        return base, lang
    return stem, None


def is_raw_subtitle_source(path: Path) -> bool:
    if path.suffix.lower() != ".srt":
        return False
    _, lang = split_subtitle_stem_and_lang(path)
    return lang is None


def build_translated_subtitle_path(raw_subtitle: Path, dest_lang: str) -> Path:
    return raw_subtitle.with_name(f"{raw_subtitle.stem}.{dest_lang}{raw_subtitle.suffix}")


# =========================================================
# ПЕРЕВОД: NLLB-200 ЛОКАЛЬНО
# =========================================================
_NLLB_PIPE = None  # ленивая инициализация


def _get_nllb_pipeline():
    global _NLLB_PIPE
    if _NLLB_PIPE is not None:
        return _NLLB_PIPE
    write_log(f"NLLB loading model: {DEFAULT_NLLB_MODEL} ...")
    try:
        import torch  # type: ignore
        from transformers import (  # type: ignore
            AutoModelForSeq2SeqLM,
            AutoTokenizer,
        )
    except ImportError as e:
        raise RuntimeError(
            "Не найден transformers/torch. Установите: "
            "pip install -q transformers sentencepiece accelerate"
        ) from e

    device = 0 if torch.cuda.is_available() else -1
    tokenizer = AutoTokenizer.from_pretrained(DEFAULT_NLLB_MODEL)
    model = AutoModelForSeq2SeqLM.from_pretrained(
        DEFAULT_NLLB_MODEL,
        torch_dtype=torch.float16 if device == 0 else torch.float32,
    )
    if device == 0:
        model = model.to("cuda")
    _NLLB_PIPE = {"tokenizer": tokenizer, "model": model, "device": device}
    write_log(f"NLLB ready (device={'cuda' if device == 0 else 'cpu'})")
    return _NLLB_PIPE


def _nllb_code(lang: str) -> str:
    code = NLLB_LANG_MAP.get(lang.lower())
    if not code:
        raise RuntimeError(
            f"Нет маппинга {lang!r} в NLLB. Добавьте код в NLLB_LANG_MAP "
            f"(https://github.com/facebookresearch/flores/blob/main/flores200/README.md)."
        )
    return code


def translate_batch_local(texts: List[str], src: str, dest: str) -> List[str]:
    if not texts:
        return []
    pipe = _get_nllb_pipeline()
    tokenizer = pipe["tokenizer"]
    model = pipe["model"]
    device = pipe["device"]

    src_code = _nllb_code(src)
    dest_code = _nllb_code(dest)

    # NLLB tokenizer ожидает src_lang заранее
    tokenizer.src_lang = src_code
    import torch  # type: ignore
    results: List[str] = []
    for start in range(0, len(texts), TRANSLATE_BATCH_SIZE):
        chunk = texts[start:start + TRANSLATE_BATCH_SIZE]
        inputs = tokenizer(
            chunk,
            return_tensors="pt",
            padding=True,
            truncation=True,
            max_length=TRANSLATE_MAX_LENGTH,
        )
        if device == 0:
            inputs = {k: v.to("cuda") for k, v in inputs.items()}

        # совместимость с разными версиями transformers
        forced_bos = None
        try:
            forced_bos = tokenizer.convert_tokens_to_ids(dest_code)
        except Exception:
            pass
        if forced_bos is None or forced_bos == tokenizer.unk_token_id:
            try:
                forced_bos = tokenizer.lang_code_to_id[dest_code]  # старый API
            except Exception as e:
                raise RuntimeError(f"Не могу получить forced_bos_token_id для {dest_code}: {e}")

        with torch.no_grad():
            out = model.generate(
                **inputs,
                forced_bos_token_id=forced_bos,
                max_length=TRANSLATE_MAX_LENGTH,
                num_beams=2,
            )
        decoded = tokenizer.batch_decode(out, skip_special_tokens=True)
        results.extend(decoded)
    return results


# =========================================================
# CHECKPOINT/META для возобновления перевода
# =========================================================
def get_state_dir(parent: Path) -> Path:
    state_dir = parent / STATE_DIR_NAME
    state_dir.mkdir(parents=True, exist_ok=True)
    return state_dir


def get_sidecar_path(target_file: Path, suffix: str) -> Path:
    state_dir = get_state_dir(target_file.parent)
    return state_dir / f"{target_file.name}{suffix}"


def get_meta_path(output_file: Path) -> Path:
    return get_sidecar_path(output_file, ".meta.json")


def load_meta(output_file: Path) -> Optional[dict]:
    meta_path = get_meta_path(output_file)
    if not meta_path.exists():
        return None
    try:
        return json.loads(meta_path.read_text(encoding="utf-8"))
    except Exception as e:
        write_log(f"WARN failed to read meta {meta_path}: {e}")
        return None


def save_meta(output_file: Path, meta: dict) -> None:
    get_meta_path(output_file).write_text(json.dumps(meta, ensure_ascii=False, indent=2), encoding="utf-8")


def make_meta(input_file: Path, output_file: Path, src_lang: str, dest_lang: str, total: int, last_done_index: int = -1) -> dict:
    return {
        "input_file": normalize_path(str(input_file)),
        "output_file": normalize_path(str(output_file)),
        "src_lang": src_lang,
        "dest_lang": dest_lang,
        "total_subs": total,
        "last_done_index": last_done_index,
        "engine": "nllb-200",
    }


def is_resume_compatible(meta: Optional[dict], input_file: Path, output_file: Path, src_lang: str, dest_lang: str, total: int) -> bool:
    if not meta:
        return False
    return (
        meta.get("input_file") == normalize_path(str(input_file))
        and meta.get("output_file") == normalize_path(str(output_file))
        and meta.get("src_lang") == src_lang
        and meta.get("dest_lang") == dest_lang
        and meta.get("total_subs") == total
        and isinstance(meta.get("last_done_index"), int)
    )


def save_checkpoint(subs, output_file: Path, meta: dict, current_index: int, total: int) -> None:
    meta["last_done_index"] = current_index
    subs.save(str(output_file), encoding="utf-8")
    save_meta(output_file, meta)
    write_log(f"TRANS SAVE [{meta['dest_lang']}] {current_index + 1}/{total}")


def is_translation_complete(input_file: Path, output_file: Path, src_lang: str, dest_lang: str) -> bool:
    if not output_file.exists():
        return False
    meta = load_meta(output_file)
    if meta is None:
        # Файл уже есть, мета отсутствует — не трогаем.
        return True
    try:
        total = len(pysrt.open(str(input_file), encoding="utf-8"))
    except Exception:
        return False
    if not is_resume_compatible(meta, input_file, output_file, src_lang, dest_lang, total):
        return True
    return int(meta.get("last_done_index", -1)) >= total - 1


def translate_subtitle_file(input_file: Path, output_file: Path, src_lang: str, dest_lang: str) -> None:
    write_log(f"TRANS START {input_file.name} -> {output_file.name} [{src_lang}->{dest_lang}]")
    original_subs = pysrt.open(str(input_file), encoding="utf-8")
    total = len(original_subs)
    meta = load_meta(output_file)

    if output_file.exists() and is_resume_compatible(meta, input_file, output_file, src_lang, dest_lang, total):
        try:
            subs = pysrt.open(str(output_file), encoding="utf-8")
        except Exception:
            subs = pysrt.open(str(input_file), encoding="utf-8")
            meta = make_meta(input_file, output_file, src_lang, dest_lang, total, -1)
            save_meta(output_file, meta)
        last_done = meta.get("last_done_index", -1) if meta else -1
        if last_done >= total - 1:
            write_log(f"TRANS DONE {dest_lang}: already complete {total}/{total}")
            return
        start_index = max(0, last_done + 1)
        write_log(f"TRANS RESUME {dest_lang}: from {start_index + 1}/{total}")
    else:
        subs = pysrt.open(str(input_file), encoding="utf-8")
        meta = make_meta(input_file, output_file, src_lang, dest_lang, total, -1)
        save_meta(output_file, meta)
        start_index = 0

    i = start_index
    while i < total:
        # собрать батч непустых строк
        indices: List[int] = []
        texts: List[str] = []
        j = i
        while j < total and len(texts) < TRANSLATE_BATCH_SIZE:
            text = subs[j].text.strip()
            if text:
                indices.append(j)
                texts.append(subs[j].text)
            j += 1

        if not texts:
            # хвост из пустых
            save_checkpoint(subs, output_file, meta, total - 1, total)
            break

        try:
            translated = translate_batch_local(texts, src_lang, dest_lang)
        except Exception as e:
            write_log(f"TRANS ERROR [{src_lang}->{dest_lang}] batch={len(texts)} -> {e}")
            # fallback: по одному, чтобы не падать всем батчем
            translated = []
            for t in texts:
                try:
                    translated.append(translate_batch_local([t], src_lang, dest_lang)[0])
                except Exception as ee:
                    write_log(f"TRANS SINGLE FAIL -> {ee}; keeping original")
                    translated.append(t)

        for sub_index, translated_text in zip(indices, translated):
            subs[sub_index].text = translated_text.strip()

        last_index_in_batch = indices[-1]
        if ((last_index_in_batch + 1) % CHECKPOINT_EVERY == 0) or (last_index_in_batch + 1 == total):
            save_checkpoint(subs, output_file, meta, last_index_in_batch, total)
        i = last_index_in_batch + 1

    if meta.get("last_done_index", -1) < total - 1:
        save_checkpoint(subs, output_file, meta, total - 1, total)
    write_log(f"TRANS DONE {output_file}")


def process_raw_subtitle(raw_subtitle: Path) -> int:
    if not is_raw_subtitle_source(raw_subtitle):
        return 0
    started = 0
    for dest_lang in Ctx.dest_langs:
        translated_output = build_translated_subtitle_path(raw_subtitle, dest_lang)
        if is_translation_complete(raw_subtitle, translated_output, Ctx.src_lang, dest_lang):
            write_log(f"TRANS SKIP {translated_output.name} already complete")
            continue
        try:
            translate_subtitle_file(raw_subtitle, translated_output, Ctx.src_lang, dest_lang)
            started += 1
        except Exception as e:
            write_log(f"TRANS ERROR {raw_subtitle.name} [{dest_lang}] -> {e}")
    return started


