def extract_episode_number(filename: str) -> Optional[str]:
    """Ищет номер серии в названии файла (32, 46, S01E05 и т.д.)"""
    # Турецкий формат: "32. Bölüm"
    match = re.search(r'(\d+)\s*\.\s*Bölüm', filename, re.IGNORECASE)
    if match:
        return match.group(1)
    
    # Обычный формат: "Episode 32", "Ep 32", "S01E32"
    match = re.search(r'(?:Episode|Ep|S\d+E)(\d+)', filename, re.IGNORECASE)
    if match:
        return match.group(1)
    
    # Просто цифра перед .srt или .mp4
    match = re.search(r'(\d+)[._-]', filename)
    if match:
        return match.group(1)
    
    return None

def find_subtitle_for_video(video: Path, lang: str) -> Optional[Path]:
    """Ищет субтитр по номеру серии и языку"""
    ep_num = extract_episode_number(video.stem)
    if not ep_num:
        return None
    
    for sub in Ctx.subtitle_dir.iterdir():
        if not sub.suffix.lower() == ".srt":
            continue
        if not sub.name.lower().endswith(f".{lang}.srt"):
            continue
        sub_ep = extract_episode_number(sub.stem)
        if sub_ep == ep_num:
            return sub
    return None

