def get_subtitle_style(video_height: int) -> str:
    font_size = round(video_height * SUB_FONT_PCT_OF_HEIGHT)
    if font_size < 18:
        font_size = 18
    outline = round(video_height * SUB_OUTLINE_PCT_OF_HEIGHT, 2)
    if outline < 0:
        outline = 0
    margin_v = int(round(video_height * SUB_MARGIN_V_PCT_OF_HEIGHT))
    if margin_v < 18:
        margin_v = 18
    return (
        f"Fontname=DejaVu Sans,Fontsize={font_size},Bold=1,BorderStyle=1,"
        f"Outline={outline},Shadow=0,PrimaryColour={SUB_PRIMARY_COLOR},"
        f"OutlineColour={SUB_OUTLINE_COLOR},Alignment=2,MarginV={margin_v}"
    )


def get_overlay_position(video_w: int, video_h: int, logo_w: int, logo_h: int, profile: Dict[str, object]) -> Tuple[int, int]:
    mx = int(round(video_w * float(profile["MarginXPct"])))
    my = int(round(video_h * float(profile["MarginYPct"])))
    anchor = str(profile["Anchor"]).replace(" ", "").lower()
    if anchor == "bottomleft":
        x, y = mx, video_h - logo_h - my
    elif anchor == "topleft":
        x, y = mx, my
    elif anchor == "bottomright":
        x, y = video_w - logo_w - mx, video_h - logo_h - my
    elif anchor == "topright":
        x, y = video_w - logo_w - mx, my
    else:
        raise ValueError(f"Unknown Anchor: {profile['Anchor']}")
    return max(0, int(x)), max(0, int(y))


