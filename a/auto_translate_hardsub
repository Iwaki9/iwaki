def validate_paths() -> None:
    if not Ctx.video_dir.exists():
        write_log(f"WARN VideoDir not found, creating: {Ctx.video_dir}")
        Ctx.video_dir.mkdir(parents=True, exist_ok=True)
    if not Ctx.subtitle_dir.exists():
        write_log(f"WARN SubtitleDir not found, creating: {Ctx.subtitle_dir}")
        Ctx.subtitle_dir.mkdir(parents=True, exist_ok=True)
    Ctx.output_dir.mkdir(parents=True, exist_ok=True)
    Ctx.log_dir.mkdir(parents=True, exist_ok=True)
    Ctx.logo_dir.mkdir(parents=True, exist_ok=True)
    get_state_dir(Ctx.output_dir)
    get_state_dir(Ctx.subtitle_dir)


def main() -> None:
    parser = argparse.ArgumentParser(description="AutoTranslate + HardSub (Kaggle edition)")
    parser.add_argument("--once", action="store_true", help="Один проход (для Kaggle — рекомендуется)")
    parser.add_argument("--video-dir", default=str(DEFAULT_VIDEO_DIR))
    parser.add_argument("--subtitle-dir", default=str(DEFAULT_SUBTITLE_DIR))
    parser.add_argument("--logo-dir", default=str(DEFAULT_LOGO_DIR))
    parser.add_argument("--output-dir", default=str(DEFAULT_OUTPUT_DIR))
    parser.add_argument("--log-dir", default=str(DEFAULT_LOG_DIR))
    parser.add_argument("--src-lang", default=os.environ.get("SRC_LANG", "tr"))
    parser.add_argument("--dest-langs", default=os.environ.get("DEST_LANGS", "en,it,es"),
                        help="Через запятую: en,it,es")
    parser.add_argument("--encoder", choices=["nvenc", "libx264", "auto"],
                        default=os.environ.get("ENCODER", "auto"))
    parser.add_argument("--skip-translation", action="store_true",
                        help="Только хардсаб, не делать перевод")
    parser.add_argument("--skip-render", action="store_true",
                        help="Только перевод, не делать хардсаб")
    parser.add_argument("--naming", choices=["stem", "workflow2"],
                        default=os.environ.get("NAMING", "stem"),
                        help="stem: video.mp4 + video.<lang>.srt (по умолчанию). "
                             "workflow2: <base>_video.mp4 + <base>_audio.<lang>.srt")
    args = parser.parse_args()

    # настраиваем Ctx
    Ctx.video_dir = Path(args.video_dir)
    Ctx.subtitle_dir = Path(args.subtitle_dir)
    Ctx.logo_dir = Path(args.logo_dir)
    Ctx.output_dir = Path(args.output_dir)
    Ctx.log_dir = Path(args.log_dir)
    Ctx.log_path = Ctx.log_dir / "AutoTranslateHardSub.log"
    Ctx.heartbeat_path = Ctx.log_dir / "AutoTranslateHardSub.heartbeat.txt"
    Ctx.src_lang = args.src_lang.lower()
    Ctx.dest_langs = [x.strip().lower() for x in args.dest_langs.split(",") if x.strip()]
    Ctx.skip_translation = args.skip_translation
    Ctx.naming = args.naming

    configure_stdio()
    ensure_commands_exist()
    validate_paths()

    Ctx.encoder = detect_encoder(args.encoder)
    write_log(f"Kaggle pipeline started")
    write_log(f"  VideoDir    = {Ctx.video_dir}")
    write_log(f"  SubtitleDir = {Ctx.subtitle_dir}")
    write_log(f"  LogoDir     = {Ctx.logo_dir}")
    write_log(f"  OutputDir   = {Ctx.output_dir}")
    write_log(f"  LogDir      = {Ctx.log_dir}")
    write_log(f"  src={Ctx.src_lang}  dest={Ctx.dest_langs}  encoder={Ctx.encoder}  naming={Ctx.naming}")
    update_heartbeat()

    videos = iter_video_files()
    subtitles = iter_subtitle_files()
    write_log(f"SCAN: videos={len(videos)} subtitles={len(subtitles)}")

    trans_started = 0
    if not Ctx.skip_translation:
        trans_started = process_translation_jobs()
    else:
        write_log("Translation skipped by flag")

    render_started = 0
    if not args.skip_render:
        render_started = process_render_jobs()
    else:
        write_log("Render skipped by flag")

    if trans_started == 0 and render_started == 0:
        write_log("IDLE: nothing to do")

    write_log("Pipeline finished")


if __name__ == "__main__":
    main()
