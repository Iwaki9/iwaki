def configure_stdio() -> None:
    for stream_name in ("stdout", "stderr"):
        stream = getattr(sys, stream_name, None)
        if stream is None:
            continue
        reconfigure = getattr(stream, "reconfigure", None)
        if callable(reconfigure):
            try:
                reconfigure(encoding="utf-8", errors="replace")
            except Exception:
                pass


def normalize_path(path: str) -> str:
    return str(Path(path).resolve()).lower()


def get_even_int(value: float) -> int:
    n = int(round(value))
    if n < 2:
        n = 2
    if n % 2 != 0:
        n -= 1
    return n


def run_checked(args: List[str], allow_non_zero: bool = False) -> subprocess.CompletedProcess:
    proc = subprocess.run(args, capture_output=True, text=True, encoding="utf-8", errors="replace")
    if proc.returncode != 0 and not allow_non_zero:
        raise RuntimeError(f"Command failed ({proc.returncode}): {' '.join(args)}\n{proc.stderr}")
    return proc


def ensure_commands_exist() -> None:
    if shutil.which(FFMPEG_PATH) is None:
        raise RuntimeError(f"FFmpeg not found: {FFMPEG_PATH}")
    if shutil.which(FFPROBE_PATH) is None:
        raise RuntimeError(f"FFprobe not found: {FFPROBE_PATH}")


def detect_encoder(preferred: str) -> str:
    """auto/nvenc/libx264 -> реально доступный."""
    if preferred == "libx264":
        return "libx264"
    # проверим наличие h264_nvenc
    try:
        proc = subprocess.run(
            [FFMPEG_PATH, "-hide_banner", "-encoders"],
            capture_output=True, text=True, encoding="utf-8", errors="replace",
        )
        has_nvenc = "h264_nvenc" in (proc.stdout or "")
    except Exception:
        has_nvenc = False
    if preferred == "nvenc":
        if not has_nvenc:
            raise RuntimeError(
                "h264_nvenc недоступен в установленном ffmpeg. "
                "Поставьте сборку BtbN со статическим nvenc "
                "(см. ячейку установки в README) или используйте --encoder libx264."
            )
        return "nvenc"
    # auto
    return "nvenc" if has_nvenc else "libx264"


def get_media_size(path: Path) -> Tuple[int, int]:
    proc = run_checked([
        FFPROBE_PATH,
        "-v", "error",
        "-select_streams", "v:0",
        "-show_entries", "stream=width,height",
        "-of", "csv=s=x:p=0",
        str(path),
    ])
    raw = proc.stdout.strip()
    if not raw or "x" not in raw:
        raise RuntimeError(f"ffprobe returned empty size for: {path}")
    w, h = raw.split("x", 1)
    return int(w), int(h)


def get_video_codec(path: Path) -> str:
    """Возвращает имя видеокодека (h264, hevc, av1, vp9, ...)"""
    try:
        proc = run_checked([
            FFPROBE_PATH,
            "-v", "error",
            "-select_streams", "v:0",
            "-show_entries", "stream=codec_name",
            "-of", "csv=p=0",
            str(path),
        ])
        return proc.stdout.strip().lower()
    except Exception:
        return ""


